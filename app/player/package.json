{
  "name": "player",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "assets:fetch": "tsx scripts/fetch-assets.ts",
    "data:defs": "tsx scripts/build-defs.ts",
    "data:scenes": "tsx scripts/build-scenes.ts",
    "data:flow": "python3 scripts/extract-flow.py",
    "data:flow:routemap": "tsx scripts/build-flow.ts",
    "data:all": "npm run data:defs && npm run data:scenes && npm run data:flow",
    "validate": "tsx scripts/validate.ts"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.6",
    "howler": "^2.2.4",
    "pixi.js": "^8.6.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/howler": "^2.2.12",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.0.18",
    "zod": "^4.1.13"
  }
}
