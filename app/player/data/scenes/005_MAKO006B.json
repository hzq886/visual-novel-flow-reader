    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "lines": [
        "「ただいま。今日も、私との約束を守って、ちゃんと",
        "来てくれたのね」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・スーツ０１・微笑み１",
        "body": "CH06B_01_01_003_01",
