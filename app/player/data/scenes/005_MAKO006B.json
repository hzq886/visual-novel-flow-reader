        "face": "CH06B_01_01_101_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "MAKO_005_MAKO006B_003",
        "file": null
      },
      "lines": [
        "「し、してるわよっ……普段からお手入れしたほうが",
        "いいって、ママに教わったし……」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・裸０１・悲しみ１",
        "body": "CH04B_01_01_001_01",
        "face": "CH04B_01_01_106_01",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "言いたくなくても、答えてしまうことになるのだ。",
        "陰毛の整え方も、母親に習ったのだろうか。",
        "おっぱいやお尻の形だけでなく、陰毛のトリミングも",
        "母娘で似ている。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・裸０１・悲しみ１",
        "body": "CH04B_01_01_001_01",
        "face": "CH04B_01_01_106_01",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO006B_006",
        "file": null
      },
      "lines": [
        "「そうそう、忘れていたわ。ちゃんと今日の報告を",
        "しておかないとね」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・裸０１・驚き１",
        "body": "CH06B_01_01_001_01",
        "face": "CH06B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "MAKO_005_MAKO006B_004",
        "file": null
      },
      "lines": [
        "「えっ？　今日の報告って、なに……？」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・裸０１・驚き１",
        "body": "CH04B_01_01_001_01",
        "face": "CH04B_01_01_104_01",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "真琴は怪訝そうに眉を寄せた。",
        "早紀さんは僕に向かって『報告』しはじめる。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・裸０１・驚き１",
        "body": "CH04B_01_01_001_01",
        "face": "CH04B_01_01_104_01",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO006B_007",
        "file": null
      },
      "lines": [
        "「ええっと、今日は私は、しょんべんを三回と、",
        "ウンコを一回したわ」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・裸０１・微笑み１",
        "body": "CH06B_01_01_001_01",
        "face": "CH06B_01_01_103_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "それは、前回、おまるで排泄をしてもらったとき、",
        "思いついたことだった。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・裸０１・微笑み１",
        "body": "CH06B_01_01_001_01",
        "face": "CH06B_01_01_103_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "lines": [
        "「ほら、真琴も、同じように報告して」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・裸０１・微笑み１",
        "body": "CH06B_01_01_001_01",
        "face": "CH06B_01_01_103_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "促されて、泣きそうになりがら、彼女は言う。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・裸０１・微笑み１",
        "body": "CH06B_01_01_001_01",
        "face": "CH06B_01_01_103_01",
        "offset": [
          265,
