{
  "code": "001_PRO003E",
  "route": "001",
  "locale": "jp",
  "beats": [
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_001",
        "file": "voice/kaed_001_pro003E_001.ogg"
      },
      "lines": [
        "「ちょっと待って！　ハンカチを忘れてるわ」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_002",
        "file": "voice/kaed_001_pro003E_002.ogg"
      },
      "lines": [
        "「はい、気を付けて行ってきてね」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_003",
        "file": "voice/kaed_001_pro003E_003.ogg"
      },
      "lines": [
        "「ふふっ、私も愛してるわ……んーっ、ちゅっ！」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_004",
        "file": "voice/kaed_001_pro003E_004.ogg"
      },
      "lines": [
        "「翼は、まだ準備が出来ていないみたい。もう少し、",
        "待っててもらえるかしら？」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_005",
        "file": "voice/kaed_001_pro003E_005.ogg"
      },
      "lines": [
        "「ああ、和樹くんね。どうぞ上がってちょうだい」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_006",
        "file": "voice/kaed_001_pro003E_006.ogg"
      },
      "lines": [
        "「あっ、いらっしゃい！　待っていたわよ」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_007",
        "file": "voice/kaed_001_pro003E_007.ogg"
      },
      "lines": [
        "「ふふっ、私は邪魔をしないから、ごゆっくり」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_008",
        "file": "voice/kaed_001_pro003E_008.ogg"
      },
      "lines": [
        "「あぁんっ……来てくれたのね。嬉しいわぁ。",
        "ずっと待ってたのよ……」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_009",
        "file": "voice/kaed_001_pro003E_009.ogg"
      },
      "lines": [
        "「もう待ちきれなくて、オマ×コが濡れ濡れに",
        "なっちゃってるのぉ」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_010",
        "file": "voice/kaed_001_pro003E_010.ogg"
      },
      "lines": [
        "「あら、もう帰っちゃうの？　もっとゆっくり",
        "していけばいいのに」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_011",
        "file": "voice/kaed_001_pro003E_011.ogg"
      },
      "lines": [
        "「それじゃあ、気を付けて帰ってね」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_012",
        "file": "voice/kaed_001_pro003E_012.ogg"
      },
      "lines": [
        "「また、いつでも来てちょうだい。待ってるから」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_013",
        "file": "voice/kaed_001_pro003E_013.ogg"
      },
      "lines": [
        "「いつでも、好きなときに、教えてあげるから。",
        "また二人で、気持ちいいコトしましょうね？」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_014",
        "file": "voice/kaed_001_pro003E_014.ogg"
      },
      "lines": [
        "「もしかして……いま、翼は初体験をしたところ？",
        "なんとなく、雰囲気で分かっちゃったわ」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_015",
        "file": "voice/kaed_001_pro003E_015.ogg"
      },
      "lines": [
        "「うふふ、処女喪失、おめでとう！　セックスって、",
        "素敵だったでしょう？」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_016",
        "file": "voice/kaed_001_pro003E_016.ogg"
      },
      "lines": [
        "「ついに翼の処女膜を破ってくれたのね、嬉しいわ！",
        "これからも、ガンガンセックスしてあげて！」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_017",
        "file": "voice/kaed_001_pro003E_017.ogg"
      },
      "lines": [
        "「避妊なんてしなくていいから、どんどん中に出して",
        "翼を妊娠させてちょうだいね！　頼んだわよ？」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_018",
        "file": "voice/kaed_001_pro003E_018.ogg"
      },
      "lines": [
        "「あら、いいじゃない！　私は嬉しいし、大歓迎よ。",
        "こんなに早く孫ができるとは思わなかったわ」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_019",
        "file": "voice/kaed_001_pro003E_019.ogg"
      },
      "lines": [
        "「子供の頃は、やんちゃで男の子みたいだったから、",
        "将来どうなることかと思っていたけれど……」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO003E_020",
        "file": "voice/kaed_001_pro003E_020.ogg"
      },
      "lines": [
        "「和樹くんが、女の悦びを教えてくれて良かったわ。",
        "娘を妊娠させてくれて、本当にありがとう！」"
      ]
    }
  ]
}
