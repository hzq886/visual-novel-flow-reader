      "bg": {
        "label": "#EV019・眉寄せ感じる・クリつまみ・興奮・モノシゴき",
        "file": "EV019_04"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU001D_025",
        "file": "voice/suzu_003_suzu001D_025.ogg"
      },
      "lines": [
        "「嗯呜！除此之外……我在工作",
        "压力大的时候，会自慰！」"
