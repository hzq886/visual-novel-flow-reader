    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU001D_029",
        "file": "voice/suzu_003_suzu001D_029.ogg"
      },
      "lines": [
        "「啊呼，哈嘶！因为是阴蒂，所以马上就，啊啊哈！能感受到！」"
