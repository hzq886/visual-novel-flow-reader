        "label": "#EV019・目細め切なげ・クリつまみ・興奮・モノシゴき・愛液",
        "file": "EV019_05"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU001D_033",
        "file": "voice/suzu_003_suzu001D_033.ogg"
