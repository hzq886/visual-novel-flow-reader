      "voice": {
        "id": "SAKI_005_MAKO005E_001",
        "file": "voice/saki_005_mako005E_001.ogg"
      },
      "lines": [
        "「知道了。真琴，带他去吧」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
