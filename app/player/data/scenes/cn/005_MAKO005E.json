        "file": "BG11_03_00"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「那么，就让我在女儿的房间里休息一下吧」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
