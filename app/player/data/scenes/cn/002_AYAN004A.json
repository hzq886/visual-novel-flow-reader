      "voice": {
        "id": "AYAN_002_AYAN004A_003",
        "file": "voice/ayan_002_ayan004A_003.ogg"
      },
      "lines": [
        "「呵呵，和君从小脸蛋就是",
        "那么光滑呢。」"
