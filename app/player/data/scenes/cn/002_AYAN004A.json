      "voice": {
        "id": "AYAN_002_AYAN004A_001",
        "file": "voice/ayan_002_ayan004A_001.ogg"
      },
      "lines": [
        "「早上好，和树」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・和樹の部屋（昼）・閉め",
        "file": "BG03_91_10"
      },
