        ]
      },
      "bgv": {
        "id": "BGV_SUZU_H003A",
        "file": "voice/BGV_suzu_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU006B_060",
        "file": "voice/suzu_003_suzu006B_060.ogg"
      },
      "lines": [
        "「啊，糟糕！要迟到了……」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常２（昼）・スーツ０１・怒り１",
