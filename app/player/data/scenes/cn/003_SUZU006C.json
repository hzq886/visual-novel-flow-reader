      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_003_SUZU006B_003",
        "file": "voice/ayan_003_suzu006B_003.ogg"
      },
      "lines": [
        "「拿去吧，小心别出事故。",
        "路上小心啊！」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprite": {
