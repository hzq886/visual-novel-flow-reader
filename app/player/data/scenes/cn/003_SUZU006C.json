        "file": "voice/BGV_suzu_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "绫姐姐急忙递给凉姐包包。",
        ""
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常２（昼）・スーツ０１・怒り１",
        "body": "CH02B_02_01_003_01",
        "face": "CH02B_02_01_105_01",
        "offset": [
          238,
          76
        ]
      },
      "bgv": {
        "id": "BGV_SUZU_H003A",
