        "id": "SUZU_004_FUTA003D_019",
        "file": "voice/suzu_004_futa003D_019.ogg"
      },
      "lines": [
        "「好的，我要在床上睡觉咯！」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常１（昼）・スーツ０１・にっこり１",
