      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_004_FUTA003D_009",
        "file": "voice/suzu_004_futa003D_009.ogg"
      },
      "lines": [
        "「啊，爸爸！快来和我一起玩吧！」"
