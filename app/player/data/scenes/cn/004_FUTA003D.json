        "offset": [
          227,
          80
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "lines": [
        "「『丝袜的雷电』」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常１（昼）・スーツ０１・悲しみ１",
