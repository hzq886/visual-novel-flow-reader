      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_004_FUTA003D_020",
        "file": "voice/suzu_004_futa003D_020.ogg"
      },
      "lines": [
        "「嗯嗯～屁股抬起来～」"
      ],
      "bg": {
        "label": "#EV040・通常",
        "file": "EV040_01"
      },
      "sprite": {
        "label": "涼菜（中）・通常１（昼）・スーツ０１・にっこり１",
