        "offset": [
          227,
          80
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "看起来喉咙好像有点干燥。"
      ],
      "bg": {
        "label": "#EV040・うふふっ・おむつ付け",
        "file": "EV040_11"
