        "offset": [
          221,
          75
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "让你回到更天真的时候吧。"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常３（昼）・スーツ０１・催眠１",
        "body": "CH02B_03_01_003_01",
        "face": "CH02B_03_01_104_01",
        "offset": [
          221,
          75
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_004_FUTA003D_006",
        "file": "voice/suzu_004_futa003D_006.ogg"
      },
      "lines": [
