        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常２（昼）・スーツ０１・怒り１",
        "body": "CH02B_02_01_003_01",
        "face": "CH02B_02_01_105_01",
        "offset": [
          238,
          76
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_004_FUTA003D_011",
        "file": "voice/suzu_004_futa003D_011.ogg"
      },
      "lines": [
