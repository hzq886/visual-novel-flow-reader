    {
      "kind": "line",
      "who": "望月真琴",
      "voice": {
        "id": "MAKO_005_MAKO001B_011",
        "file": "voice/mako_005_mako001B_011.ogg"
      },
      "lines": [
        "「啊，果然！你对她做了什么吧！？」"
      ],
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・驚き１",
          "body": "CH04B_01_02_004_01",
          "face": "CH04B_01_02_104_01",
          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「你，你把自己放在一边说别人，你说什么呢！",
