          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "",
        "她非常惊讶和慌乱。"
      ],
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・驚き１",
          "body": "CH04B_01_02_004_01",
          "face": "CH04B_01_02_104_01",
          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「我对真琴使用了催眠术，然后问了她。」"
      ],
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・驚き１",
