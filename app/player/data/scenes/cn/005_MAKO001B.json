          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "将所做之事原原本本地传达给她。",
        "因为我用催眠术控制着她，所以没有特别需要隐藏的必要。"
      ],
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・驚き１",
          "body": "CH04B_01_02_004_01",
