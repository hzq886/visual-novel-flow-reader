            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「什，什么叫变态啊！」"
      ],
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・怒り１",
          "body": "CH04B_01_02_004_01",
          "face": "CH04B_01_02_105_01",
          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "被戳中要害，我结结巴巴地回答。"
      ],
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・怒り１",
          "body": "CH04B_01_02_004_01",
          "face": "CH04B_01_02_105_01",
