      "voice": {
        "id": "MAKO_005_MAKO001A_025",
        "file": "voice/mako_005_mako001A_025.ogg"
      },
      "lines": [
        "「啊，呃……你一个人在教室里，怎么了？」"
      ],
      "bg": {
        "label": "#背景・廊下（昼）",
        "file": "BG15_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・制服０１・微笑み１",
