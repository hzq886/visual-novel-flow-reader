        "face": "CH04B_01_02_104_01",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「真琴，你的学生会工作已经结束了吗？」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
