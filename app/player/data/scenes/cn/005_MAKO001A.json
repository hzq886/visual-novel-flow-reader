      "voice": {
        "id": "MAKO_005_MAKO001A_026",
        "file": "voice/mako_005_mako001A_026.ogg"
      },
      "lines": [
        "「看起来你有点累，没事吧？」"
      ],
      "bg": {
        "label": "#背景・廊下（昼）",
