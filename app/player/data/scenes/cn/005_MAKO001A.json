        "file": "BG16_92_00"
      },
      "sprite": {
        "label": "真琴（中）・通常３（夕）・制服０１・眠り１",
        "body": "CH04B_03_02_004_01",
        "face": "CH04B_03_02_103_01",
        "offset": [
          238,
          128
        ]
      }
    },
