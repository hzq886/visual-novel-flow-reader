      "voice": {
        "id": "MAKO_005_MAKO001A_027",
        "file": "voice/mako_005_mako001A_027.ogg"
      },
      "lines": [
        "「嗯，一起回去吧！」"
      ],
      "bg": {
        "label": "#背景・廊下（昼）",
        "file": "BG15_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（夕）・制服０１・呆れ１",
