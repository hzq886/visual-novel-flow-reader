        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "然后，让你忘记来教室后的对话和游戏的事情。"
      ],
      "bg": {
        "label": "#背景・廊下（昼）",
        "file": "BG15_01_00"
