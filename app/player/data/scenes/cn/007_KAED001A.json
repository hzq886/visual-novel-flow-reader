    },
    {
      "kind": "line",
      "who": "楠木枫",
      "voice": {
        "id": "KAED_007_KAED001A_034",
        "file": "voice/kaed_007_kaed001A_034.ogg"
      },
      "lines": [
        "「全部脱光，躺在床上仰面向上好吗？",
        "我要在上面……」"
      ],
      "bg": {
        "label": "#背景・楠木夫婦の寝室（昼）",
