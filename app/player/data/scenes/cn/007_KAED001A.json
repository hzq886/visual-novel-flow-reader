        "face": "CH05B_01_01_101_01",
        "offset": [
          234,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木枫",
      "lines": [
        "「但是我真的很淫荡，想立刻就舔上枫小姐的小穴你知道吗？」"
      ],
      "bg": {
        "label": "#背景・楠木夫婦の寝室（昼）",
        "file": "BG10_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・エロ下着０１・通常１",
        "body": "CH05B_01_01_004_01",
        "face": "CH05B_01_01_101_01",
        "offset": [
          234,
          70
