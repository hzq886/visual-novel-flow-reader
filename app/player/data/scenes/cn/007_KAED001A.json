      "bg": {
        "label": "#背景・楠木夫婦の寝室（昼）",
        "file": "BG10_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・エロ下着０１・うっとり１",
        "body": "CH05B_01_01_004_01",
        "face": "CH05B_01_01_103_01",
        "offset": [
          234,
          70
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "你特意用粗俗的话说出来真是太棒了。",
        "不仅仅是因为暗示的缘故，枫小姐似乎天生就很淫荡。",
        "这应该算是一个令人高兴的意外吧。"
      ],
      "bg": {
        "label": "#背景・楠木夫婦の寝室（昼）",
        "file": "BG10_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・エロ下着０１・うっとり１",
        "body": "CH05B_01_01_004_01",
        "face": "CH05B_01_01_103_01",
        "offset": [
          234,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木枫",
      "lines": [
        "「那么，我们来实际尝试一下，看看能有多淫荡，来比试一下吧！」"
      ],
      "bg": {
        "label": "#背景・楠木夫婦の寝室（昼）",
        "file": "BG10_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・エロ下着０１・うっとり１",
        "body": "CH05B_01_01_004_01",
        "face": "CH05B_01_01_103_01",
        "offset": [
          234,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木枫",
      "voice": {
        "id": "KAED_007_KAED001A_033",
        "file": "voice/kaed_007_kaed001A_033.ogg"
      },
      "lines": [
        "「呵呵，好啊！来吧！」"
