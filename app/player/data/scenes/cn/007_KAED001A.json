        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "然后，对陷入催眠状态的她说道。"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
