        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木翼",
      "lines": [
        "「啊！？啊，啊，哈啊啊……」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
