        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木翼",
      "lines": [
        "「晚餐……叫你之前，躺在床上……」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
