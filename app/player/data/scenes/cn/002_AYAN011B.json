      "bg": {
        "label": "#EV046・アヘ顔・エロ下着",
        "file": "EV046_05"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "为了抵抗紧紧的压迫感，我一次又一次地插入肉棒。",
        ""
      ],
      "bg": {
        "label": "#EV046・アヘ顔・エロ下着",
        "file": "EV046_05"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「就这样射出来吧，绫姐！」"
      ],
      "bg": {
        "label": "#EV046・アヘ顔・エロ下着",
        "file": "EV046_05"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
