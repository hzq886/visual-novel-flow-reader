      "bg": {
        "label": "#EV046・眉寄せ・エロ下着",
        "file": "EV046_01"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN011B_024",
        "file": "voice/ayan_002_ayan011B_024.ogg"
      },
      "lines": [
        "「咕呜，嗯嗯，嗯咕！啊啊，嗯哈啊！",
        "嗯嗯嗯，呼呼，嗯嗯唔！」"
      ],
      "bg": {
        "label": "#EV046・眉寄せ・エロ下着",
        "file": "EV046_01"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "姐姐发出了稍微有些痛苦的声音，拼命地摆动着腰部。",
        "",
        "虽然可以慢慢地进出，但还是感觉很痛苦吧。",
        ""
