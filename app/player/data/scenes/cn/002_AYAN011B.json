    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN011B_047",
        "file": "voice/ayan_002_ayan011B_047.ogg"
      },
      "lines": [
        "「哦呼呼！太厉害了！！在肛门里，喷射着热热的精液，流出来了～！」"
