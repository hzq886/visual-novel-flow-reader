      "voice": {
        "id": "AYAN_002_AYAN011B_043",
        "file": "voice/ayan_002_ayan011B_043.ogg"
      },
      "lines": [
        "「嗯哈啊！啊啊，啊嘿！嗯哦哦！",
        "嗯啊，啊啊，啊呜！哦呼呼呼！」"
      ],
      "bg": {
        "label": "#EV046・アヘ顔・エロ下着",
