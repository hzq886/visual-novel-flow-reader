      "bg": {
        "label": "#EV046・アヘ顔・エロ下着",
        "file": "EV046_05"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "沉迷其中的绫姐如此渴望着。",
        "我回应着她，更有力地插入。"
