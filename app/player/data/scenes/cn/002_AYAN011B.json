      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "姐姐高兴地点了点头，配合我的动作和节奏，大幅度地摆动着腰部。",
