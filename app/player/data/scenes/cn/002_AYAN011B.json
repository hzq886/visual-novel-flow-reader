      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "绫姐满意地深深地呼出一口气。",
        "沉浸在极致的余韵中，屁眼的紧缩终于松弛下来。",
