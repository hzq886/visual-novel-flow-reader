      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN011B_035",
        "file": "voice/ayan_002_ayan011B_035.ogg"
      },
      "lines": [
        "「哈啊，哈啊！嗯嗯嗯！肉棒真厉害！",
        "嗯哦哦，哦哦，哦呼呼！」"
