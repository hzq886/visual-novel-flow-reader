      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN011B_050",
        "file": "voice/ayan_002_ayan011B_050.ogg"
      },
      "lines": [
        "「哈啊……从现在开始，我只要大便一下就会……」"
