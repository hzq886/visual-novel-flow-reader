        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN011B_033",
        "file": "voice/ayan_002_ayan011B_033.ogg"
      },
      "lines": [
        "「更，更激烈地动吧，嗯哦，哦哦！",
        "嗯嗯嗯，哈呜！」"
      ],
      "bg": {
        "label": "#EV046・喘ぎ・エロ下着",
