    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN011B_032",
        "file": "voice/ayan_002_ayan011B_032.ogg"
      },
      "lines": [
        "「哦，哈呜！嗯嗯！哦呼！肛，肛门好热！呼唔，嗯哦呼！」"
