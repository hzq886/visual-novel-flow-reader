      "bg": {
        "label": "#EV046・眉寄せ・エロ下着",
        "file": "EV046_01"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN011B_028",
        "file": "voice/ayan_002_ayan011B_028.ogg"
      },
      "lines": [
        "「嗯呼！嗯咕！咕！唔唔呼！",
