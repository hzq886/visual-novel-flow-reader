      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN011B_027",
        "file": "voice/ayan_002_ayan011B_027.ogg"
      },
      "lines": [
        "「哈呜！嗯嗯唔！哈哈，哈哈！",
        "你也帮忙了呢……嗯呼啊！」"
      ],
      "bg": {
        "label": "#EV046・眉寄せ・エロ下着",
