    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN011B_031",
        "file": "voice/ayan_002_ayan011B_031.ogg"
      },
      "lines": [
        "「嗯嗯！嗯呼！嗯呼！哈呜！肛，肛门擦到了",
