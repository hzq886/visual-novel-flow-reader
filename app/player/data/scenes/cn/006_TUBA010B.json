      "bg": {
        "label": "#EV054・虚ろ目眉寄せ・股間舐め・制服",
        "file": "EV054_02"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・下着０１・催眠１",
        "body": "CH03B_03_01_002_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木翼",
      "voice": {
        "id": "TUBA_006_TUBA010B_016",
        "file": "voice/tuba_006_tuba010B_016.ogg"
      },
      "lines": [
        "「呼啊……肚子里面，感觉刺痛……嗯啊……」"
      ],
      "bg": {
        "label": "#EV054・虚ろ目眉寄せ・股間舐め・制服・愛液",
        "file": "EV054_03"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・下着０１・催眠１",
