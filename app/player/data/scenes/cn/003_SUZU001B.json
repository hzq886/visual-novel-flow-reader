        "face": "CH02B_02_01_104_01",
        "offset": [
          238,
          76
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「需要别人帮忙，一个人试不了」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（昼）",
        "file": "BG05_01_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常２（昼）・室内着０１・驚き１",
        "body": "CH02B_02_01_006_01",
        "face": "CH02B_02_01_104_01",
        "offset": [
          238,
          76
        ]
      }
    },
    {
