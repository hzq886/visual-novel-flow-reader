      "bg": {
        "label": "#背景・涼菜の部屋（昼）",
        "file": "BG05_01_00"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「顺便问一下，凉姐在应试的时候，是怎么提高",
