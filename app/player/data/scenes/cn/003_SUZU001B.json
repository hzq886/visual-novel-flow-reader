      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU001B_005",
        "file": "voice/suzu_003_suzu001B_005.ogg"
      },
      "lines": [
        "「啊，我也读过一些关于提高注意力的放松方法的东西」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（昼）",
