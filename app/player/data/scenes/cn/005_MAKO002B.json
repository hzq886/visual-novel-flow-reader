        }
      ],
      "bgv": {
        "id": "BGV_MAKO_H002A",
        "file": "voice/BGV_mako_h002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "挣扎着，用手指夹住阴蒂，左右滚动。",
        "乳头也被手指捏住，转来转去。",
        "乳头和阴蒂的快感仿佛连接在一起，电流般的快感相互传递。"
      ],
      "bg": {
        "label": "#EV076・うっとり蕩け・持ち上げ・愛液",
