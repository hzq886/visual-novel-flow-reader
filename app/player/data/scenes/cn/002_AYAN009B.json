      "bg": {
        "label": "#EV043・うっとり・ローション・半分くらい挿入",
        "file": "EV043_02"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「嗯……非常舒服！」"
