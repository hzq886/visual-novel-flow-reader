      "bg": {
        "label": "#EV043・うっとり・ローション・半分くらい挿入",
        "file": "EV043_02"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN009B_002",
        "file": "voice/ayan_002_ayan009B_002.ogg"
      },
      "lines": [
        "「那么，我稍微动一下好吗？」"
