  "title": "望月真琴\\N忘记了她",
  "beats": [
    {
      "kind": "narration",
      "lines": [
        "放学时间到了，我向真琴搭话。"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
        "file": "BG16_01_00"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「对不起！放学后能借你的笔记吗？」"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
        "file": "BG16_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・制服０１・通常１",
        "body": "CH04B_01_01_004_01",
