      "voice": {
        "id": "MOBA_001_PRO001K_001",
        "file": "voice/moba_001_pro001K_001.ogg"
      },
      "lines": [
        "「绫菜，你差不多要毕业了吧？接下来",
        "打算怎么办呢？」"
