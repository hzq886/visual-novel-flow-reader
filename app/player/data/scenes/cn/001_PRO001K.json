        "offset": [
          318,
          172
        ]
      }
    },
    {
      "kind": "line",
      "who": "亲戚叔父",
      "voice": {
        "id": "MOBA_001_PRO001K_003",
        "file": "voice/moba_001_pro001K_003.ogg"
      },
      "lines": [
        "「老夫妇是我认识的，他们经营着一家咖啡店。",
        "因为年纪大了，打算停下来了」"
