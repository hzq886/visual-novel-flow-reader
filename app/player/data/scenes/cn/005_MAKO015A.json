        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "我再次被迫忏悔。"
      ],
      "bg": {
        "label": "#背景・真琴の部屋（昼）",
        "file": "BG12_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・裸０１・悲しみ１",
        "body": "CH04B_01_01_001_01",
        "face": "CH04B_01_01_106_01",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "line",
