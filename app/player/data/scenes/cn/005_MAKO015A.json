      "voice": {
        "id": "MAKO_005_MAKO015A_003",
        "file": "voice/mako_005_mako015A_003.ogg"
      },
      "lines": [
        "「这样一来，我或许也有机会和和树交往，",
        "至少是这样想的……」"
      ],
      "bg": {
        "label": "#背景・真琴の部屋（昼）",
        "file": "BG12_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・裸０１・悲しみ１",
