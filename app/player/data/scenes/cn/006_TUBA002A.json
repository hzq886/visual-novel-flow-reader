    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「可以吗？当你和古桥和树说话或者被他触碰时，会感到快乐的哦」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（夕）・制服０１・催眠１",
        "body": "CH03B_03_02_004_01",
        "face": "CH03B_03_02_104_01",
        "offset": [
