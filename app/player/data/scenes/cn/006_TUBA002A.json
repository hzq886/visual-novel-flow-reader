      "voice": {
        "id": "TUBA_006_TUBA002A_001",
        "file": "voice/tuba_006_tuba002A_001.ogg"
      },
      "lines": [
        "「说话……被触碰的话，会很开心」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（夕）・制服０１・催眠１",
