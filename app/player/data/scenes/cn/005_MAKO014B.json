      "bg": {
        "label": "#EV025・苦悶",
        "file": "EV025_02"
      }
    },
    {
      "kind": "narration",
      "pages": [
        [
          "和树又给我看了台词本。"
        ],
        [
          "不说话是为了不让声音进入视频吧。"
