      "bg": {
        "label": "#EV025・苦悶",
        "file": "EV025_02"
      }
    },
    {
      "kind": "narration",
      "pages": [
        [
          ""
        ],
        [
          "又要说些蠢话了。"
        ],
        [
          "明明不想被看到。"
