      ],
      "bg": {
        "label": "#EV025・苦悶",
        "file": "EV025_02"
      }
    },
    {
      "kind": "line",
      "who": "望月真琴",
      "voice": {
        "id": "MAKO_005_MAKO014B_004",
        "file": "voice/mako_005_mako014B_004.ogg"
      },
      "lines": [
        "「呜呜……快，快要排便了，好好看着啊！」"
