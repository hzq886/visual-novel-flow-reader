      ],
      "bg": {
        "label": "#EV025・苦悶",
        "file": "EV025_02"
      }
    },
    {
      "kind": "line",
      "who": "望月真琴",
      "voice": {
        "id": "MAKO_005_MAKO014B_005",
        "file": "voice/mako_005_mako014B_005.ogg"
      },
      "lines": [
        "「不要只盯着小穴看！要好好注视着上面的小便孔哦！」"
