          331,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木翼",
      "lines": [
        "「应该没事吧？」"
      ],
      "bg": {
        "label": "#背景・楠木家外観（昼）",
        "file": "BG07_01_00"
      },
      "sprite": {
