        "offset": [
          331,
          70
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "接着，枫小姐立刻追了出来。"
      ],
      "bg": {
        "label": "#背景・楠木家外観（昼）",
        "file": "BG07_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・私服０１・驚き１",
