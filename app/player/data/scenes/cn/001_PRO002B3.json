      "voice": {
        "id": "KAED_001_PRO002B3_003",
        "file": "voice/kaed_001_pro002B3_003.ogg"
      },
      "lines": [
        "「翼，你忘记带便当了！拿去，这个！」"
      ],
      "bg": {
        "label": "#背景・楠木家外観（昼）",
        "file": "BG07_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・私服０１・驚き１",
        "body": "CH05B_01_01_003_01",
        "face": "CH05B_01_01_104_01",
        "offset": [
          234,
          70
        ]
      }
    },
    {
