      "who": "楠木翼",
      "voice": {
        "id": "TUBA_001_PRO002B3_002",
        "file": "voice/tuba_001_pro002B3_002.ogg"
      },
      "lines": [
        "「啊，不好！这可是最重要的东西啊！」"
