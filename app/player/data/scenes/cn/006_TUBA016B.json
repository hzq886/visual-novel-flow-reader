      "bg": {
        "label": "#EV086・うっとり悶え・挿入・愛液",
        "file": "EV086_06"
      },
      "bgv": {
        "id": "BGV_TUBA_H002A",
        "file": "voice/BGV_tuba_h002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「射出来了，翼！我要射到最深处！」"
      ],
      "bg": {
        "label": "#EV086・うっとり悶え・挿入・愛液",
