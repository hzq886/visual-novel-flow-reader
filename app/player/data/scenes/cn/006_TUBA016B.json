      },
      "bgv": {
        "id": "BGV_TUBA_H002A",
        "file": "voice/BGV_tuba_h002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "voice": {
        "id": "TUBA_006_TUBA016B_024",
        "file": "voice/tuba_006_tuba016B_024.ogg"
      },
      "lines": [
        "「小穴，好幸福啊，啊，呼啊呀！我也要",
        "射了，停不下来了！嗯啊啊！」"
