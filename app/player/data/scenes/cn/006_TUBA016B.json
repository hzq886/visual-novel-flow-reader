        "file": "EV086_08"
      },
      "bgv": {
        "id": "BGV_TUBA_H002A",
        "file": "voice/BGV_tuba_h002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "翼这样诱人地撒娇着。",
        "我的回答已经决定了。"
