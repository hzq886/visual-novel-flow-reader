      "voice": {
        "id": "TUBA_006_TUBA016B_017",
        "file": "voice/tuba_006_tuba016B_017.ogg"
      },
      "lines": [
        "「这，这个，肉棒又开始抽搐了！",
        "啊嗯，啊，嗯呀啊！」"
