      "bg": {
        "label": "#EV011・虚ろ目ぼんやり・横向き穿いてる・愛液染み",
        "file": "EV011_01"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「如果不是尿尿，那你的下体为什么会湿呢？」"
      ],
      "bg": {
        "label": "#EV011・虚ろ目ぼんやり・横向き穿いてる・愛液染み",
