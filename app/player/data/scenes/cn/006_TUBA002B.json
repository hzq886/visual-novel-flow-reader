    {
      "kind": "line",
      "who": "楠木翼",
      "voice": {
        "id": "TUBA_006_TUBA002B_004",
        "file": "voice/tuba_006_tuba002B_004.ogg"
      },
      "lines": [
        "「是的，没错……感觉到了，很舒服……",
