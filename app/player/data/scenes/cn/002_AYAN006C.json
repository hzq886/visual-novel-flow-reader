      "bg": {
        "label": "#EV018・目閉じ・挿入後・破瓜",
        "file": "EV018_05"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN006C_036",
        "file": "voice/ayan_002_ayan006C_036.ogg"
      },
      "lines": [
        "「嗯嗯……啊，这里……嗯啊！稍微，",
        "这个地方……感觉不错……啊啊！」"
      ],
      "bg": {
        "label": "#EV018・微笑み・挿入後・破瓜",
        "file": "EV018_06"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "看来靠近入口的浅部分确实很舒服。",
        "亀头上摩擦的触感很舒服。",
        "绫姐的动作似乎是在强烈刺激亀头上方的部分。"
