      "who": "望月真琴",
      "voice": {
        "id": "MAKO_006_TUBA019A_001",
        "file": "voice/mako_006_tuba019A_001.ogg"
      },
      "lines": [
        "「说谎……明明早就在这里等了好久了……」"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・私服０１・呆れ１",
        "body": "CH04B_02_01_003_01",
        "face": "CH04B_02_01_107_01",
        "offset": [
          238,
          135
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "真琴的话被无视了。",
        "不仅是对我，对翼也是如此。"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・私服０１・呆れ１",
        "body": "CH04B_02_01_003_01",
        "face": "CH04B_02_01_107_01",
        "offset": [
          238,
          135
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木翼",
      "voice": {
        "id": "TUBA_006_TUBA019A_002",
        "file": "voice/tuba_006_tuba019A_002.ogg"
      },
      "lines": [
        "「那么，我们去约会吧！去哪里？」"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・私服０２・にっこり１",
