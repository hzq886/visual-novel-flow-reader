        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「没事的。我刚刚到这里来的」"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・私服０２・通常１",
        "body": "CH03B_02_01_003_02",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
