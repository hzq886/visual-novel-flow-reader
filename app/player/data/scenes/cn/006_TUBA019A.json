        "face": "CH04B_01_01_105_01",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月真琴",
      "lines": [
        "「翼可以决定。去哪里？」"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・私服０１・怒り１",
