          "offset": [
            227,
            80
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「说过肩膀酸痛的事情了，对吧？」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常１（昼）・室内着０１・驚き１",
          "body": "CH02B_01_01_006_01",
          "face": "CH02B_01_01_104_01",
          "offset": [
            227,
            80
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "凉姐微笑着说道。"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常１（昼）・室内着０１・驚き１",
          "body": "CH02B_01_01_006_01",
          "face": "CH02B_01_01_104_01",
          "offset": [
            227,
            80
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_012",
        "file": "voice/suzu_003_suzu002B_012.ogg"
      },
      "lines": [
        "「啊，对了！我肩膀很酸……那么，能帮我揉胸吗？」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常２（昼）・室内着０１・にっこり１",
          "body": "CH02B_02_01_006_01",
          "face": "CH02B_02_01_102_01",
          "offset": [
            238,
            76
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "",
        "我咕噜了一下喉咙。",
        "然后，仿佛确认了一样询问道。"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常２（昼）・室内着０１・にっこり１",
          "body": "CH02B_02_01_006_01",
          "face": "CH02B_02_01_102_01",
          "offset": [
            238,
            76
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「额……揉胸就可以了吗？」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常２（昼）・室内着０１・にっこり１",
          "body": "CH02B_02_01_006_01",
          "face": "CH02B_02_01_102_01",
          "offset": [
            238,
            76
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_013",
        "file": "voice/suzu_003_suzu002B_013.ogg"
      },
      "lines": [
        "「是的，就是这样。因为揉胸对肩膀酸痛最有效。",
        "我想让你揉我的胸部」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常２（昼）・室内着０１・にっこり１",
          "body": "CH02B_02_01_006_01",
          "face": "CH02B_02_01_102_01",
          "offset": [
            238,
            76
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "姐姐毫不在意地说出了令人惊讶的话。",
        "我兴奋得身体颤抖了一下。"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常２（昼）・室内着０１・にっこり１",
          "body": "CH02B_02_01_006_01",
          "face": "CH02B_02_01_102_01",
          "offset": [
            238,
            76
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「嗯，嗯……揉胸就可以了吗？」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常２（昼）・室内着０１・にっこり１",
          "body": "CH02B_02_01_006_01",
          "face": "CH02B_02_01_102_01",
          "offset": [
            238,
            76
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_014",
        "file": "voice/suzu_003_suzu002B_014.ogg"
      },
      "lines": [
        "「还有，在揉的同时能亲吻我吗？",
        "这样做对缓解肩膀酸痛更有效」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常２（昼）・室内着０１・通常１",
          "body": "CH02B_02_01_006_01",
          "face": "CH02B_02_01_101_01",
          "offset": [
            238,
            76
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "以暗示的方式，将其作为理所当然的事情来说。",
        "甚至不理解自己实际上在追求什么。"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常２（昼）・室内着０１・通常１",
          "body": "CH02B_02_01_006_01",
          "face": "CH02B_02_01_101_01",
          "offset": [
            238,
            76
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「那，那就……揉胸吧。」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常２（昼）・室内着０１・通常１",
          "body": "CH02B_02_01_006_01",
          "face": "CH02B_02_01_101_01",
          "offset": [
            238,
            76
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_015",
        "file": "voice/suzu_003_suzu002B_015.ogg"
      },
      "lines": [
        "「呵呵，好好地揉一揉吧。」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常２（昼）・室内着０１・にっこり１",
          "body": "CH02B_02_01_006_01",
          "face": "CH02B_02_01_102_01",
          "offset": [
            238,
            76
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "我从背后靠近坐在床上的凉姐……"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常２（昼）・室内着０１・にっこり１",
          "body": "CH02B_02_01_006_01",
          "face": "CH02B_02_01_102_01",
          "offset": [
            238,
            76
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "然后有力地抓住了她的胸部。"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_016",
        "file": "voice/suzu_003_suzu002B_016.ogg"
      },
      "lines": [
        "「嗯啊！啊，啊哈啊……啊！」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "凉姐发出声音，身体颤抖了一下。"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「难道，疼吗！？」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_017",
        "file": "voice/suzu_003_suzu002B_017.ogg"
      },
      "lines": [
        "「不，没关系的。只是有点刺激而已。」"
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "其实是我刺激得比较厉害。",
        "听着凉姐淫荡的声音，感受着手中温暖的胸部，我的心脏一直急速跳动着。",
        ""
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「是不是应该更轻柔地揉一下呢？」"
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "声音好像要上涨，让人有点紧张。",
        "但是，凉姐笑着说道。"
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_018",
        "file": "voice/suzu_003_suzu002B_018.ogg"
      },
      "lines": [
        "「不，就这样继续吧。刺激更强的话，",
        "对缓解肩膀酸痛应该更有效果」"
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "于是，为了『缓解肩膀酸痛』，我揉捏着凉姐的",
        "胸部。",
        "这样一握，我发现它比外表看起来要丰满得多。",
        "",
        "手掌感受到沉甸甸的，舒适的重量。"
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_019",
        "file": "voice/suzu_003_suzu002B_019.ogg"
      },
      "lines": [
        "「嗯……嗯，嗯……啊，果然，",
        "被揉捏胸部真是太好了……」"
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "手中的胸部异常柔软。",
        "一揉捏，它颤动着，在我的手中改变形状。",
        "",
        "握紧时，它会被压扁，从指缝中挤出。",
        "",
        "松开手指，它会轻轻扩散开来，贴在我的手上。",
        ""
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_020",
        "file": "voice/suzu_003_suzu002B_020.ogg"
      },
      "lines": [
        "「嗯……嗯……嗯嗯……就这样……！",
        "嗯嗯嗯，就这样……」"
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "虽然很柔软，但手压上去的弹力也很强。",
        "每次揉捏，温暖的胸部在手中弹跳。",
        "用揉肩的力度，使劲地揉捏着。"
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_021",
        "file": "voice/suzu_003_suzu002B_021.ogg"
      },
      "lines": [
        "「嗯嗯，哈啊，哈啊！呼……不行，",
        "感觉太舒服了，发出了奇怪的声音」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "凉姐微微扭动了一下身体。"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「没关系的，可以更大声一点哦」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_022",
        "file": "voice/suzu_003_suzu002B_022.ogg"
      },
      "lines": [
        "「是，是吗？和树这么说的话……啊！",
        "啊呼……嗯嗯，好舒服！」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "不在意是不可能的事情。",
        "实际上，听到凉姐可爱的喘息声，我的下半身开始隐隐作痛。",
        "",
        "为了听到更多的声音，我狠狠地揉捏着凉姐的胸部。",
        ""
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_023",
        "file": "voice/suzu_003_suzu002B_023.ogg"
      },
      "lines": [
        "「嗯嗯……嗯哈……嗯嗯……啊呃！",
        "嘿，别忘了亲吻哦。」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "凉姐这样说着，抬头看着我。",
        "她整齐的脸庞微微泛红。",
        "我兴奋地用干涩的喉咙说道。"
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「我应该亲吻凉姐吗？」"
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_024",
        "file": "voice/suzu_003_suzu002B_024.ogg"
      },
      "lines": [
        "「是的，我想要一边揉捏胸部一边亲吻。」"
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "听到这样的要求，我的下体变得坚硬起来。",
        "我小心地避开了凸起的下体，将脸靠近凉姐的脸庞。",
        "",
        "然后，紧紧抓住她的胸部，我与姐姐的唇相互交融。",
        ""
      ],
      "bg": {
        "label": "#EV005・真面目顔・戸惑い・ワシ掴み",
        "file": "EV005_02"
      },
      "bgv": {
        "id": "BGV_SUZU_H001A",
        "file": "voice/BGV_suzu_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_025",
        "file": "voice/suzu_003_suzu002B_025.ogg"
      },
      "lines": [
        "「嗯嗯……嗯吮……嗯，呼……吮」"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "小小温暖的唇触感。",
        "得到凉姐的初吻，一种无比的喜悦充满全身。",
        "",
        "我陶醉其中，一次又一次地亲吻着。",
        "同时，我紧握着她的胸部。"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_026",
        "file": "voice/suzu_003_suzu002B_026.ogg"
      },
      "lines": [
        "「啾，嗯啾！嗯啊，呼……啾！",
        "嗯，嗯，嗯……咕嘟，啾！」"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "丰满的双唇非常柔软。",
        "不仅手掌心，连唇部都仿佛要融化了一样。",
        "柔软而有弹性，就像胸部一样。",
        "每次唇相触，都会轻轻地压迫着。"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_027",
        "file": "voice/suzu_003_suzu002B_027.ogg"
      },
      "lines": [
        "「嗯嗯，呼啊，啊嗯，啾啾！",
        "呼啊，力量仿佛被抽走了……嗯嗯！」"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "凉姐闭上双眼，接受了我的吻和手的动作。",
        "",
        "每次呼出气息时，她那长长的睫毛微微颤动。",
        "我一边凝视着她美丽的脸庞，一边用各种方式揉捏着手中的胸部。",
        "",
        "从下方用力抬起，手掌紧贴着，轻轻地摇晃着。",
        ""
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_028",
        "file": "voice/suzu_003_suzu002B_028.ogg"
      },
      "lines": [
        "「咕噜噜，嗯噗！啊……啾！",
        "啾嘟，嗯啾……嗯啾，啾！」"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "感觉很舒服，凉姐轻轻地颤抖了一下背部。",
        "乳房在手中颤抖着跳动，仿佛要从背心中跳出来一样。",
        "",
        "就这样，我深入揉捏着指尖。"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_029",
        "file": "voice/suzu_003_suzu002B_029.ogg"
      },
      "lines": [
        "「嗯呼，啊哈！这样揉捏……嗯啊！",
        "好舒服……哈，哈……！」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "凉姐的呼吸变得有些粗重。",
        "唇的粉红色看起来更加浓郁。",
        "我把嘴唇轻轻擦过微微张开的嘴唇。"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め・戸惑い・ワシ掴み",
        "file": "EV005_01"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_030",
        "file": "voice/suzu_003_suzu002B_030.ogg"
      },
      "lines": [
        "「嗯呼，呼……嘟噜，吮吸，嘟噜！",
        "啊呀，嗯嗯！嗯啊……吮吸！」"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "当两个最凸起的部分相互摩擦时，一股舒适感沿着脊椎传遍全身。",
        "",
        "当唇角接触到时，感觉好像要发出声音。",
        "就这样，上下左右地移动，充分了解凉姐的唇形。",
        ""
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_031",
        "file": "voice/suzu_003_suzu002B_031.ogg"
      },
      "lines": [
        "「吧唧，吮吸，嘟噜……吮吸，啊呀……吮吸，吧唧……吮吸！」"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "",
        "同时，用手揉捏着她的胸部，充分享受形状和柔软度。",
        "",
        "用五根手指抚摸着乳房。",
        "特别是拇指直接接触到裸露的皮肤，感觉更加有力。",
        "",
        "用拇指轻抚着有弹性的皮肤，凉姐的声音逐渐变得柔和。",
        ""
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_032",
        "file": "voice/suzu_003_suzu002B_032.ogg"
      },
      "lines": [
        "「啊哈，哈……嘟，嘟……呼啊！",
        "用指腹用力按压，让它深入」"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "在接吻的距离里说话，热气喷在身上，",
        "不由得身体颤抖了一下。"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「咬，深入进去吗……」"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_033",
        "file": "voice/suzu_003_suzu002B_033.ogg"
      },
      "lines": [
        "「对，用手指……在胸部……嗯啊！ 嗯，",
        "嗯……！ 嗯呼！」"
      ],
      "bg": {
        "label": "#EV005・目閉じチュー・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_03"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "手指深入进去，凉姐的身体颤了一下。",
        "洗发水的香味飘动着，透明的香气",
        "刺激着鼻腔。",
        "洗发水的香味和升高的体温，让我",
        "越来越兴奋。",
        "就这样，用力揉捏着柔软的乳房",
        "把手指按进去。"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め2・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_04"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_034",
        "file": "voice/suzu_003_suzu002B_034.ogg"
      },
      "lines": [
        "「啊啊，那里……嗯嗯嗯，有点刺激！",
        "更多……嗯咂，嘟噜！」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め2・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_04"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "因为粗暴地对待胸部而产生的",
        "征服感，像是一种黑暗的情绪。",
        "触摸着温暖柔软的乳房，产生一种安心感的感觉。",
        "",
        "在两种感觉中摇摆不定，紧紧贴上嘴唇。"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め2・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_04"
      },
      "bgv": {
        "id": "BGV_SUZU_F001A",
        "file": "voice/BGV_suzu_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_035",
        "file": "voice/suzu_003_suzu002B_035.ogg"
      },
      "lines": [
        "「啪嗒！啪嗒，噗啪嗒！嗯呼，噗噗啪，嗯呼，呼啊！」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め2・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_04"
      },
      "bgv": {
        "id": "BGV_SUZU_F002A",
        "file": "voice/BGV_suzu_f002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "",
        "不断溢出的呼吸声，让唇部变得湿润。",
        "湿润的唇部感觉像是吸附在一起。",
        "紧密贴合的双唇互相吸吮。"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め2・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_04"
      },
      "bgv": {
        "id": "BGV_SUZU_F002A",
        "file": "voice/BGV_suzu_f002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_036",
        "file": "voice/suzu_003_suzu002B_036.ogg"
      },
      "lines": [
        "「啾啾，嗯啾啾……嗯啾！",
        "哇……这感觉真是太舒服了……！」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め2・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_04"
      },
      "bgv": {
        "id": "BGV_SUZU_F002A",
        "file": "voice/BGV_suzu_f002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "喘息般的声音传出后，又立即贴上唇部。",
        "",
        "双唇紧密贴合，同时揉捏着手中的乳房。",
        "",
        "凉姐的圆肩微微颤抖了一下。"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め2・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_04"
      },
      "bgv": {
        "id": "BGV_SUZU_F002A",
        "file": "voice/BGV_suzu_f002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_037",
        "file": "voice/suzu_003_suzu002B_037.ogg"
      },
      "lines": [
        "「嗯，啊！啊……噗啪，嗯嗯！",
        "嗯啾，嗯嗯，嗯啾……噗啊，啊！」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め2・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_04"
      },
      "bgv": {
        "id": "BGV_SUZU_F002A",
        "file": "voice/BGV_suzu_f002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "无论怎样揉捏，凉姐都会发出喘息声，露出痛苦的反应。",
        "",
        "凉姐还是处女。",
        "因为是第一次，所以很敏感吧。",
        "这么想着，下体变得更加坚硬。",
        "在做着各种事情的同时，我注意到了一件事。",
        "从根部开始，顺着指尖滑动揉捏，反应最大。",
        "",
        "像搓弄乳房一样动手。"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め2・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_04"
      },
      "bgv": {
        "id": "BGV_SUZU_F002A",
        "file": "voice/BGV_suzu_f002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_038",
        "file": "voice/suzu_003_suzu002B_038.ogg"
      },
      "lines": [
        "「嗯，嗯哼……啊呀，嗯啊啊！嗯！",
        "嗯啊……啊……！啊哈哈……！」"
      ],
      "bg": {
        "label": "#EV005・眉寄せ目細め2・戸惑い・ワシ掴み・唇押し付け合い",
        "file": "EV005_04"
      },
      "bgv": {
        "id": "BGV_SUZU_F002A",
        "file": "voice/BGV_suzu_f002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "靠近顶端，但没有触碰到乳头就回来时，凉姐的腰左右摆动。",
        "",
        "就像腰部在不安地扭动一样。",
        "而且，透露出的呼吸声，不是表现出舒服的样子，而是显得遗憾……。",
        "",
        "再一次，从乳房根部向前滑动手指。",
        ""
