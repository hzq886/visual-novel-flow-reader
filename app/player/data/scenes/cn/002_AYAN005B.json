    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN005B_038",
        "file": "voice/ayan_002_ayan005B_038.ogg"
      },
      "lines": [
        "「啊啊，好厉害……！和君的精液的味道，太棒了……呼啊啊……」"
      ],
      "bg": {
        "label": "#EV004・目見開き・尻穴に指入れ・精液",
