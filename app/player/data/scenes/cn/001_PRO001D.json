        "file": "voice/kaed_001_pro001D_002.ogg"
      },
      "lines": [
        "「啊，欢迎。请直接进来吧。」"
      ],
      "bg": {
        "label": "#背景・楠木家外観（幼少・昼）",
        "file": "BG07_11_00"
      }
    },
    {
      "kind": "narration",
      "lines": [
