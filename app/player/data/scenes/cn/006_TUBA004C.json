      "voice": {
        "id": "TUBA_006_TUBA004C_019",
        "file": "voice/tuba_006_tuba004C_019.ogg"
      },
      "lines": [
        "「嗯嗯……噗哈！啊啊，可惜，就差一点点了！」"
