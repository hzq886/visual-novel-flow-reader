        "file": "EV082_06"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "voice": {
        "id": "AYAN_002_AYAN013B_032",
        "file": "voice/ayan_002_ayan013B_032.ogg"
      },
      "lines": [
