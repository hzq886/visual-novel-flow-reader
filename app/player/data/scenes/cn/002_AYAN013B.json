      "bg": {
        "label": "#EV082・軽くアヘ・あり・奥まで挿入・愛液",
        "file": "EV082_06"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "voice": {
        "id": "AYAN_002_AYAN013B_026",
        "file": "voice/ayan_002_ayan013B_026.ogg"
      },
      "lines": [
