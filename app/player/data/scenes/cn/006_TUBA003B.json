        "face": "CH05B_01_01_102_01",
        "offset": [
          234,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「首先，放松身体，意识集中在头顶上方。",
        "然后，用这根手指……」"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（昼）",
        "file": "BG08_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・私服０１・にっこり１",
        "body": "CH05B_01_01_003_01",
        "face": "CH05B_01_01_102_01",
        "offset": [
          234,
          70
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
