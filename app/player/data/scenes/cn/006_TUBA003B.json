  "title": "楠木翼\\N在翼家做作业",
  "beats": [
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「那个，枫小姐」"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（昼）",
        "file": "BG08_01_00"
      },
      "sprite": {
