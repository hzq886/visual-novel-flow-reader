  "title": "望月真琴\\N望月家",
  "beats": [
    {
      "kind": "narration",
      "lines": [
        "……数日后。",
        "我暂时向真琴确认了一下。",
        "是否按照指示行动了。"
      ],
      "bg": {
        "label": "#背景・学院前（昼）",
        "file": "BG14_01_00"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「准确地按照说的做了吗？」"
      ],
      "bg": {
        "label": "#背景・学院前（昼）",
        "file": "BG14_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・制服０１・悲しみ１",
        "body": "CH04B_01_01_004_01",
