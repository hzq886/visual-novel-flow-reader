        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月真琴",
      "lines": [
        "「那么，我们去真琴的房间吧。」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（昼）",
        "file": "BG11_01_00"
