      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・裸１１・悲しみ２",
        "body": "CH04B_01_01_001_11",
        "face": "CH04B_01_01_106_02",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月早纪",
      "voice": {
        "id": "SAKI_005_MAKO006C_020",
        "file": "voice/saki_005_mako006C_020.ogg"
      },
      "lines": [
