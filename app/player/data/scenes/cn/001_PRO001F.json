      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
      },
      "sprite": {
        "label": "旧真琴（中）・通常１（昼）・私服０１・驚き１",
        "body": "CH24B_01_01_001_01",
        "face": "CH24B_01_01_103_01",
        "offset": [
          205,
          354
        ]
