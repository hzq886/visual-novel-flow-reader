        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月早纪",
      "voice": {
        "id": "MAKO_005_MAKO006B_001",
        "file": "voice/mako_005_mako006B_001.ogg"
      },
      "lines": [
