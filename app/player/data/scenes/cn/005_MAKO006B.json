    },
    {
      "kind": "line",
      "who": "望月早纪",
      "voice": {
        "id": "SAKI_005_MAKO006B_005",
        "file": "voice/saki_005_mako006B_005.ogg"
      },
      "lines": [
        "「当然会啦。形象很重要嘛。",
        "嗯，虽然没有人能看到……」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・裸０１・通常１",
