        "offset": [
          238,
          135
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月早纪",
      "voice": {
        "id": "MAKO_005_MAKO006B_002",
        "file": "voice/mako_005_mako006B_002.ogg"
      },
      "lines": [
