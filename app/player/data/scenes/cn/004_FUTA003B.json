        "label": "#EV040・もじもじ・おむつ付け",
        "file": "EV040_04"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_004_FUTA003B_007",
        "file": "voice/suzu_004_futa003B_007.ogg"
      },
      "lines": [
        "「尿尿呀，快点出来……嗯嗯，嗯～！",
        "小便啊，快出来吧！」"
