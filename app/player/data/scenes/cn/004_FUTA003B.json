    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_004_FUTA003B_009",
        "file": "voice/suzu_004_futa003B_009.ogg"
      },
      "lines": [
        "「啊啊啊，小便出来了……哈啊啊。",
