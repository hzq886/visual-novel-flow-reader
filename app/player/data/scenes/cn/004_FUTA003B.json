      "bg": {
        "label": "#EV040・うふふっ・下敷き尿・尿",
        "file": "EV040_06"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_004_FUTA003B_017",
        "file": "voice/suzu_004_futa003B_017.ogg"
      },
      "lines": [
        "「擦擦小阴部，谢谢你……嗯呼，",
