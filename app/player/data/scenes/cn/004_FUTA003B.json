      "bg": {
        "label": "#EV040・通常・おむつ付け",
        "file": "EV040_03"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_004_FUTA003B_005",
        "file": "voice/suzu_004_futa003B_005.ogg"
      },
      "lines": [
