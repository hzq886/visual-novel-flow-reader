      "bg": {
        "label": "#EV040・安堵・おむつ付け",
        "file": "EV040_05"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_004_FUTA003B_013",
        "file": "voice/suzu_004_futa003B_013.ogg"
      },
      "lines": [
        "「嗯……看啊，凉的小阴唇，湿透了。",
