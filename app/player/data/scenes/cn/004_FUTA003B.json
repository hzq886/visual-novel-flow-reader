      ],
      "bg": {
        "label": "#EV040・うふふっ・下敷き尿・尿",
        "file": "EV040_06"
      }
    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_004_FUTA003B_016",
        "file": "voice/suzu_004_futa003B_016.ogg"
      },
      "lines": [
        "「拜托了，请擦擦已经湿透的",
        "凉的小阴部吧！」"
