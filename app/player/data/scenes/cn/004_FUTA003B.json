    },
    {
      "kind": "line",
      "who": "古桥凉菜",
      "voice": {
        "id": "SUZU_004_FUTA003B_011",
        "file": "voice/suzu_004_futa003B_011.ogg"
      },
      "lines": [
        "「啊呜呜……小便完了。凉的小阴唇，湿湿的。」"
