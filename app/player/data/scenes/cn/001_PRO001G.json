      "sprite": {
        "label": "旧翼（中）・通常１（昼）・私服０１・にっこり１",
        "body": "CH23B_01_01_001_01",
        "face": "CH23B_01_01_102_01",
        "offset": [
          125,
          300
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木翼",
      "voice": {
        "id": "TUBA_001_PRO001G_005",
        "file": "voice/tuba_001_pro001G_005.ogg"
      },
      "lines": [
        "「我们可以试着用催眠术解决一下？」"
      ],
      "bg": {
        "label": "#背景・幼少時教室（幼少）",
        "file": "BG24_11_00"
