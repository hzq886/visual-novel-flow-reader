    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「催眠术……这个嘛，我觉得",
        "可能行不通呢……」"
      ],
      "bg": {
        "label": "#背景・幼少時教室（幼少）",
        "file": "BG24_11_00"
