      "voice": {
        "id": "MAKO_001_PRO001G_002",
        "file": "voice/mako_001_pro001G_002.ogg"
      },
      "lines": [
        "「不……我想和你们两个一起玩……」"
      ],
      "bg": {
        "label": "#背景・幼少時教室（幼少）",
        "file": "BG24_11_00"
