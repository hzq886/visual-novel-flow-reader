      "who": "楠木翼",
      "voice": {
        "id": "TUBA_001_PRO001G_006",
        "file": "voice/tuba_001_pro001G_006.ogg"
      },
      "lines": [
        "「总之，先试试看吧！嘿，我还带来了五角硬币！和钱哥，看这边！」"
      ],
      "bg": {
        "label": "#背景・幼少時教室（幼少）",
