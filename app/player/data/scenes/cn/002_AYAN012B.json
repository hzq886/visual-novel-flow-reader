        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_015",
        "file": "voice/ayan_002_ayan012B_015.ogg"
      },
      "lines": [
        "「哈啊，哈啊，嗯嗯……往里面顶进去，",
        "这种感觉……嗯呼，太难忍了……！」"
      ],
      "bg": {
        "label": "#EV067・目細め",
        "file": "EV067_01"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "果然一直在等待这种刺激吧。",
        "",
        "绫姐姐的声音越来越甜蜜迷人。"
      ],
      "bg": {
        "label": "#EV067・目細め",
        "file": "EV067_01"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_016",
        "file": "voice/ayan_002_ayan012B_016.ogg"
      },
      "lines": [
        "「嗯呼，嗯嗯，哦哦……哦呼……！」"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "即使是缓慢的进出，反应也越来越好。",
        "偶尔发出动物般的声音，紧紧地夹住",
        "我的肉棒。"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_017",
        "file": "voice/ayan_002_ayan012B_017.ogg"
      },
      "lines": [
        "「嗯呼，嗯哦，呼哦哦！深入浅出地，",
        "磨擦着屁眼，好喜欢……哦，嗯呼……！」"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "姐姐的声音真的很舒服。"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「宝宝没事吧……？」"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "伸出手，试着抚摸着绫姐姐的大肚子。"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_018",
        "file": "voice/ayan_002_ayan012B_018.ogg"
      },
      "lines": [
        "「哈啊，哈啊……嗯，我觉得没关系……不要",
        "担心，继续……啊，嗯嗯……！」"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "如果绫姐姐这么说，应该真的没问题吧。",
        "不过话说回来，在这个大肚子里，是不是有",
        "我和绫姐姐的宝宝呢？",
        "抚摸着肚子，心中涌起一种难以言喻的亲切",
        "感。"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_019",
        "file": "voice/ayan_002_ayan012B_019.ogg"
      },
      "lines": [
        "「嘿嘿，嗯嗯，嗯哦……！ 哦，噢呼！",
        "嗯哦哦……！ 啊啊，好舒服……！」"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "保持这种感觉，继续刺激姐姐的肛门。",
        "我和绫姐姐都越来越兴奋。"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_020",
        "file": "voice/ayan_002_ayan012B_020.ogg"
      },
      "lines": [
        "「哈哈，哈哈，又被戳进去了，肛门被",
        "磨擦着真是太好了……啊啊，太棒了！」"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "姐姐感受到的动作，我一遍又一遍地重复。"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_021",
        "file": "voice/ayan_002_ayan012B_021.ogg"
      },
      "lines": [
        "「哦，噢呼！有种拉屎的感觉，",
        "太喜欢了！嗯呼呀……！」"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "被这刺激，绫姐姐身子扭动着。",
        "屁眼也不断地收紧着我的肉棒，仿佛在传达着喜悦的感觉。",
        "",
        "但渐渐地，好像已经不够了，她一边晃动着屁股，一边低声嘟囔着。",
        ""
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_022",
        "file": "voice/ayan_002_ayan012B_022.ogg"
      },
      "lines": [
        "「嗯哈……虽然很舒服，但小穴却在疼痛，感觉被拖延得好厉害……」"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "",
        "怀孕之前我们曾经那么激烈，所以也是可以理解的吧。",
        "",
        "这种缓慢的动作肯定不够刺激。"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_023",
        "file": "voice/ayan_002_ayan012B_023.ogg"
      },
      "lines": [
        "「呼呼，请用粗大的肉棒狠狠地戳进我的菊花里」"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "",
        "虽然我知道姐姐很焦躁……"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「真的激烈一点没关系吗？」"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_024",
        "file": "voice/ayan_002_ayan012B_024.ogg"
      },
      "lines": [
        "「已经进入稳定期了，应该没问题的，请……我已经忍不住了！」"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "",
        "绫姐姐焦躁地晃动着屁股向我求求。",
        "既然你这么说了，我也不能不回应。",
        "如果感觉不太好的话，中途可以再慢慢调整一下动作。",
        "",
        "为了减轻负担，紧紧抱住腰部，重新开始。",
        "",
        "然后有力地插入肉棒。"
      ],
      "bg": {
        "label": "#EV067・うっとり蕩け",
        "file": "EV067_02"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_025",
        "file": "voice/ayan_002_ayan012B_025.ogg"
      },
      "lines": [
        "「嗯嗯……哦，哦哦……哦呼！」"
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "慢慢加快节奏，像以前那样猛烈地抽插。",
        "",
        "绫姐姐对此有着敏锐的反应，发出愉悦的声音。",
        ""
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H002A",
        "file": "voice/BGV_ayan_h002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_026",
        "file": "voice/ayan_002_ayan012B_026.ogg"
      },
      "lines": [
        "「好！啊啊，被猛烈地戳进去，真是太棒了！嗯嗯，哦呼啊！」"
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "",
        "用力插入肉棒，她也用同样强烈的收缩回应着。",
        "",
        "继续抽插下去，像拖拉着姐姐的肛门一样的动作。",
        ""
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_027",
        "file": "voice/ayan_002_ayan012B_027.ogg"
      },
      "lines": [
        "「嗨呀！嗯嗯，呼呼！啊，呜啊！",
        "嗯啊，好舒服！嗯呼呼！」"
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "比怀孕前更加紧致了。",
        "以为是错觉，但并非如此。",
        "肚子变大后，会不会对肛门产生影响呢？",
        ""
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_028",
        "file": "voice/ayan_002_ayan012B_028.ogg"
      },
      "lines": [
        "「啊呜，嗯嗯，嗯哦！哦，呼哦！",
        "更深入一点，更深入一点！」"
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "姐姐也摇动着腰部，以各种角度相互摩擦。",
        "",
        "随着腰部的推进，巨大的胸部和肚子摇晃着。",
        ""
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_029",
        "file": "voice/ayan_002_ayan012B_029.ogg"
      },
      "lines": [
        "「哦，哦呼，太棒了！嗯哦哦，哦呼！",
        "也在小穴中回荡着，嘿呀！」"
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "看着绫姐姐享受着快感，我也陶醉其中不断地动着腰部。",
        "",
        "绫姐姐的肛门渗出了肠液，在收缩的同时也变得更加滑润。",
        ""
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_030",
        "file": "voice/ayan_002_ayan012B_030.ogg"
      },
      "lines": [
        "「哈，哈，哦呼！嗯呼，嗯哦哦！",
        "嗯嗯，嗯哈！哦酷，嗯呼呼！！」"
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "姐姐的声音越来越大，变得充满兽性。",
        "",
        "肛门不断地收缩，对肉棒的刺激也不断增强。",
        ""
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_031",
        "file": "voice/ayan_002_ayan012B_031.ogg"
      },
      "lines": [
        "「哦呼！肛门，哦，哦呼！嗯呼，肛门好像要融化了！哦呼呼！」"
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        ""
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「快要射了，绫姐姐！」"
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "随着剧烈的动作，射精感越来越强烈。"
      ],
      "bg": {
        "label": "#EV067・アヘ顔",
        "file": "EV067_03"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_032",
        "file": "voice/ayan_002_ayan012B_032.ogg"
      },
      "lines": [
