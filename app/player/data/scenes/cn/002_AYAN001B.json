      "bg": {
        "label": "#背景・喫茶店（夕）",
        "file": "BG20_02_00"
      },
      "sprite": {
        "label": "綾菜（中）・通常２（夕）・私服０２・通常１",
        "body": "CH01B_02_02_003_02",
        "face": "CH01B_02_02_101_01",
        "offset": [
          431,
          78
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "lines": [
        "「我要在这张纸的中间写上小字，你能仔细看着，读出来吗？」"
