      },
      "sprite": {
        "label": "綾菜（中）・通常２（夕）・私服０２・悲しみ１",
        "body": "CH01B_02_02_003_02",
        "face": "CH01B_02_02_106_01",
        "offset": [
          431,
          78
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "lines": [
