      "bg": {
        "label": "#背景・喫茶店（夕）",
        "file": "BG20_02_00"
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN001B_001",
        "file": "voice/ayan_002_ayan001B_001.ogg"
      },
      "lines": [
        "「郡山先生？嗯，最近他没有来过。",
        "没有任何联络……」"
