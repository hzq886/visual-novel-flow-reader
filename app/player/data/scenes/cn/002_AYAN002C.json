          78
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "我再次询问。",
        "为了确认『暗示』的效果。"
      ],
      "bg": {
        "label": "#背景・綾菜の部屋（夜）",
        "file": "BG04_03_00"
      },
      "sprite": {
        "label": "綾菜（中）・通常２（昼）・下着０１・困り１",
        "body": "CH01B_02_01_002_01",
        "face": "CH01B_02_01_107_01",
        "offset": [
          431,
          78
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥绫菜",
      "lines": [
        "「你是在想着我然后自慰吗？」"
      ],
      "bg": {
        "label": "#背景・綾菜の部屋（夜）",
        "file": "BG04_03_00"
      },
      "sprite": {
        "label": "綾菜（中）・通常２（昼）・下着０１・困り１",
        "body": "CH01B_02_01_002_01",
        "face": "CH01B_02_01_107_01",
        "offset": [
