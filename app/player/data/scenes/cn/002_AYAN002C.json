      "who": "古桥绫菜",
      "voice": {
        "id": "AYAN_002_AYAN002C_012",
        "file": "voice/ayan_002_ayan002C_012.ogg"
      },
      "lines": [
        "「对对！想着你自慰的话，会非常兴奋，感觉比平时更强烈！」"
