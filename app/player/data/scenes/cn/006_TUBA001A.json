        "body": "CH03B_03_02_004_01",
        "face": "CH03B_03_02_103_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "这样，翼陷入了催眠状态。",
        "从这里，进一步进入更深的状态。"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
