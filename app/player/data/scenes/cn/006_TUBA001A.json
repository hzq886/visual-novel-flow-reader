        "body": "CH03B_03_02_004_01",
        "face": "CH03B_03_02_103_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「一下子就松弛下来，感觉非常舒服。",
        "头部轻飘飘地晃动着，感觉很舒服呢。」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（夕）・制服０１・眠り１",
