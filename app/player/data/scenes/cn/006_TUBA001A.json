        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（夕）・制服０１・ポカン１",
        "body": "CH03B_03_02_004_01",
        "face": "CH03B_03_02_101_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「因为不能看到移动的手指哦？」"
