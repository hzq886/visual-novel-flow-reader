        "face": "CH03B_03_02_103_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "一直意识着的头顶部位。",
        "用缓慢的话语轻轻晃动那里。"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
      },
      "sprite": {
