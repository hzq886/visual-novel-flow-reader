        "body": "CH03B_03_02_004_01",
        "face": "CH03B_03_02_102_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "古桥和树",
      "lines": [
        "「可能有点用力了，放松一下吧」"
