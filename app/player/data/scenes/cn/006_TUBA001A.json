      "who": "楠木翼",
      "voice": {
        "id": "TUBA_006_TUBA001A_012",
        "file": "voice/tuba_006_tuba001A_012.ogg"
      },
      "lines": [
        "「哇哦……这个有点难……」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（夕）・制服０１・驚愕１",
