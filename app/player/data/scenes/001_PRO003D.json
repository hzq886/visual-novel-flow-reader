{
  "code": "001_PRO003D",
  "route": "001",
  "locale": "jp",
  "beats": [
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_001",
        "file": null
      },
      "lines": [
        "「おはよう！　今日もいい天気だねっ！」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_002",
        "file": null
      },
      "lines": [
        "「おはよう！　なんか今日は、傘を持って行った",
        "ほうがいいみたいだよ！」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_003",
        "file": null
      },
      "lines": [
        "「おまたせー！　ごめんね、バタバタしちゃって！」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_004",
        "file": null
      },
      "lines": [
        "「おまたせ。いつも迎えに来てくれて、ありがとう」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_005",
        "file": null
      },
      "lines": [
        "「おはよう、真琴ちゃん！」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_006",
        "file": null
      },
      "lines": [
        "「あっ、そうなんだ……それなら、仕方ないね。",
        "それにしても、大変そうだねー」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_007",
        "file": null
      },
      "lines": [
        "「それじゃあ、いこっか！」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_008",
        "file": null
      },
      "lines": [
        "「どうしたの？　なにか考えごとでもしてるの？」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_009",
        "file": null
      },
      "lines": [
        "「今日は、陸上部で遅くなると思うから、先に帰って",
        "もらってもいいかな？」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_010",
        "file": null
      },
      "lines": [
        "「うん、それじゃあ、また明日ね！」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_011",
        "file": null
      },
      "lines": [
        "「はい……ひとりで、かえります……」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO003D_012",
        "file": null
      },
      "lines": [
        "「そっかぁ。それじゃあ、ボクは先に帰るね！」"
      ]
    }
  ]
}
