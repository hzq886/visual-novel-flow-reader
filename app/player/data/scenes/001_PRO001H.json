        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_001_PRO001H_004",
        "file": "voice/mako_001_pro001H_004.ogg"
      },
      "lines": [
        "「ありがとう……かずきくん……」"
      ],
      "bg": {
        "label": "#背景・幼少時教室（幼少）",
        "file": "BG24_11_00"
      },
      "sprite": {
        "label": "旧真琴（中）・通常１（昼）・私服０１・にっこり１",
