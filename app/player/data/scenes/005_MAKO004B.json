        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そう言われれば、確かにそうだ。",
        "不在ということなら、それはそれで構わない。",
        "その間に、楽しませてもらうことにしよう。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（昼）",
        "file": "BG11_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・制服０１・怒り１",
