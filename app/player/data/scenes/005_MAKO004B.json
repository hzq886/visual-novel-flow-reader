        "file": "voice/mako_005_mako004B_001.ogg"
      },
      "lines": [
        "「はい、言われた通りしましたっ……ううっ……」"
      ],
      "bg": {
        "label": "#背景・学院前（昼）",
        "file": "BG14_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・制服０１・悲しみ１",
