{
  "code": "001_PRO003B",
  "route": "001",
  "locale": "jp",
  "beats": [
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_001",
        "file": "voice/suzu_001_pro003B_001.ogg"
      },
      "lines": [
        "「おはよう。少し寝坊しちゃったわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_002",
        "file": "voice/suzu_001_pro003B_002.ogg"
      },
      "lines": [
        "「おはよう。新聞を取ってくるわね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_003",
        "file": "voice/suzu_001_pro003B_003.ogg"
      },
      "lines": [
        "「ちゃんと寝たの？　夜ふかしは良くないわよ？」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_004",
        "file": "voice/suzu_001_pro003B_004.ogg"
      },
      "lines": [
        "「いただきます。姉さんの食事は、いつもバランスが",
        "良くて助かるわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_005",
        "file": "voice/suzu_001_pro003B_005.ogg"
      },
      "lines": [
        "「これ、すごく美味しいわね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_006",
        "file": "voice/suzu_001_pro003B_006.ogg"
      },
      "lines": [
        "「ごめんなさい。ちょっと時間が無いから、",
        "もう出るわね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_007",
        "file": "voice/suzu_001_pro003B_007.ogg"
      },
      "lines": [
        "「ええ、分かったわ。ありがとう」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_008",
        "file": "voice/suzu_001_pro003B_008.ogg"
      },
      "lines": [
        "「それじゃあ、いってきます」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_009",
        "file": "voice/suzu_001_pro003B_009.ogg"
      },
      "lines": [
        "「今日は、帰りが遅くなるかもしれないわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_010",
        "file": "voice/suzu_001_pro003B_010.ogg"
      },
      "lines": [
        "「ただいま。今日は早く帰れたわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_011",
        "file": "voice/suzu_001_pro003B_011.ogg"
      },
      "lines": [
        "「ただいま。ちょっと遅くなっちゃったわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_012",
        "file": "voice/suzu_001_pro003B_012.ogg"
      },
      "lines": [
        "「とりあえず、部屋で着替えてくるわね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_013",
        "file": "voice/suzu_001_pro003B_013.ogg"
      },
      "lines": [
        "「ありがとう。すぐに着替えてくるわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_014",
        "file": "voice/suzu_001_pro003B_014.ogg"
      },
      "lines": [
        "「いつもながら、姉さんの料理は最高ね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_015",
        "file": "voice/suzu_001_pro003B_015.ogg"
      },
      "lines": [
        "「うん、美味しいわ。なかなかのものよ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_016",
        "file": "voice/suzu_001_pro003B_016.ogg"
      },
      "lines": [
        "「それじゃあ、お風呂に入るわね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_017",
        "file": "voice/suzu_001_pro003B_017.ogg"
      },
      "lines": [
        "「ちょっと部屋で、仕事をするわね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_018",
        "file": "voice/suzu_001_pro003B_018.ogg"
      },
      "lines": [
        "「すこし部屋で、休ませてもらうわね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_019",
        "file": "voice/suzu_001_pro003B_019.ogg"
      },
      "lines": [
        "「それじゃあ、おやすみなさい」"
      ]
    }
  ],
  "bgm": {
    "track": "M01",
    "file": "bgm/M01.ogg"
  }
}
