        "offset": [
          125,
          300
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "ごく自然な感じの、素朴な疑問。",
        "僕は、特に気にせず、正直に答えた。"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
      },
      "sprite": {
        "label": "旧翼（中）・通常１（昼）・私服０１・困惑１",
        "body": "CH23B_01_01_001_01",
        "face": "CH23B_01_01_106_01",
        "offset": [
          125,
          300
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「あっ、ウチはお父さんとお母さんがいないんだ」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
      },
      "sprite": {
        "label": "旧翼（中）・通常１（昼）・私服０１・困惑１",
        "body": "CH23B_01_01_001_01",
        "face": "CH23B_01_01_106_01",
        "offset": [
          125,
          300
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO001C_006",
        "file": null
      },
      "lines": [
        "「そ、そうなんだ……えっと、ごめん……」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
      },
      "sprite": {
        "label": "旧翼（中）・通常１（昼）・私服０１・悲しみ１",
        "body": "CH23B_01_01_001_01",
        "face": "CH23B_01_01_105_01",
        "offset": [
          125,
          300
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "謝る翼に、あわてて言う。"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
      },
      "sprite": {
        "label": "旧翼（中）・通常１（昼）・私服０１・悲しみ１",
        "body": "CH23B_01_01_001_01",
        "face": "CH23B_01_01_105_01",
        "offset": [
          125,
          300
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「でもほら、姉さんたちが、お父さんとお母さん",
        "がわりっていうか……そんなかんじだから」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
      },
      "sprite": {
        "label": "旧翼（中）・通常１（昼）・私服０１・悲しみ１",
        "body": "CH23B_01_01_001_01",
        "face": "CH23B_01_01_105_01",
        "offset": [
          125,
          300
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO001C_007",
        "file": null
      },
      "lines": [
        "「お姉ちゃんが……ところで、あやなさんって、",
        "すっごいきれいなひとだよね！」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
      },
      "sprite": {
        "label": "旧翼（中）・通常１（昼）・私服０１・悲しみ１",
        "body": "CH23B_01_01_001_01",
        "face": "CH23B_01_01_105_01",
        "offset": [
          125,
          300
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
