      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
      },
      "sprite": {
        "label": "旧翼（中）・通常１（昼）・私服０１・悲しみ１",
        "body": "CH23B_01_01_001_01",
        "face": "CH23B_01_01_105_01",
        "offset": [
          125,
          300
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "うらやましそうに言うのも、きっとわざとだ。",
        "母親の楓さんと同じで、翼も、とても優しい。",
        "そして、そんな話をしていたとき……。",
        "涼菜姉さんが帰ってきた。"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
