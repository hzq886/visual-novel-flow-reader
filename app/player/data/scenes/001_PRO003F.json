{
  "code": "001_PRO003F",
  "route": "001",
  "locale": "jp",
  "beats": [
    {
      "kind": "line",
      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO003F_001",
        "file": "voice/mobd_001_pro003F_001.ogg"
      },
      "lines": [
        "「ごめんごめん！　ありがとう」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO003F_002",
        "file": "voice/mobd_001_pro003F_002.ogg"
      },
      "lines": [
        "「ああ、行ってくる。愛してるよ、楓」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO003F_003",
        "file": "voice/mobd_001_pro003F_003.ogg"
      },
      "lines": [
        "「やあ、おはよう。翼を迎えに来てくれたんだね？」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO003F_004",
        "file": "voice/mobd_001_pro003F_004.ogg"
      },
      "lines": [
        "「それじゃあ私は行くけれど、後はよろしくね」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO003F_005",
        "file": "voice/mobd_001_pro003F_005.ogg"
      },
      "lines": [
        "「いらっしゃい。今日はどうしたんだい」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO003F_006",
        "file": "voice/mobd_001_pro003F_006.ogg"
      },
      "lines": [
        "「そうか、ゆっくりしていっておくれ」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO003F_007",
        "file": "voice/mobd_001_pro003F_007.ogg"
      },
      "lines": [
        "「おや、帰るところかい？　気を付けてね」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO003F_008",
        "file": "voice/mobd_001_pro003F_008.ogg"
      },
      "lines": [
        "「さようなら。また、いつでも来ておくれ」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO003F_009",
        "file": "voice/mobd_001_pro003F_009.ogg"
      },
      "lines": [
        "「うーん、まだ学生だし、少し軽率だったんじゃ",
        "ないかい？」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO003F_010",
        "file": "voice/mobd_001_pro003F_010.ogg"
      },
      "lines": [
        "「まぁ、いまさら言っても仕方ないか。和樹くん、",
        "娘を幸せにしてくれよ？」"
      ]
    },
    {
      "kind": "line",
      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO003F_011",
        "file": "voice/mobd_001_pro003F_011.ogg"
      },
      "lines": [
        "「いやー、こんなに早く、孫ができるとはなぁー！",
        "和樹くん、翼を幸せにしてやってくれよ！」"
      ]
    }
  ],
  "bgm": {
    "track": "M01",
    "file": "bgm/M01.ogg"
  }
}
