      "voice": {
        "id": "SUZU_003_SUZU001A_002",
        "file": null
      },
      "lines": [
        "「いいわよ？　なんの教科を教えて欲しいの？」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（昼）",
        "file": "BG05_01_00"
