        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "教えてもらうこと自体は、普段からしていることだ。",
        "特に、不審に思われたりはしないだろう。",
        "そうして僕は、問題集を取り出してみせる。"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（昼）",
        "file": "BG05_01_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常１（昼）・室内着０１・通常１",
        "body": "CH02B_01_01_006_01",
        "face": "CH02B_01_01_101_01",
        "offset": [
          227,
          80
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "lines": [
        "「この、数学の問題なんだけど……」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（昼）",
        "file": "BG05_01_00"
