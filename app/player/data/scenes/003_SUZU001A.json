    {
      "kind": "line",
      "who": "古橋　涼菜",
      "lines": [
        "「ちょっと、勉強を教えてもらいたいんだけど」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（昼）",
        "file": "BG05_01_00"
      },
      "sprite": {
