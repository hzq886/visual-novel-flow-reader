        "face": "CH02B_03_01_104_01",
        "offset": [
          221,
          75
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_008",
        "file": null
      },
      "lines": [
