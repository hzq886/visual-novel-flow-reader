        "face": "CH02B_03_01_104_01",
        "offset": [
          221,
          75
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_003_SUZU002B_009",
        "file": null
      },
      "lines": [
        "「おっぱい、もまれながら、きす……さらに、",
