          221,
          75
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "lines": [
        "「いいですか……肩こりを改善するには、おっぱいを",
        "揉まれるのが、いちばん良いです」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常３（昼）・室内着０１・催眠１",
        "body": "CH02B_03_01_006_01",
        "face": "CH02B_03_01_104_01",
        "offset": [
          221,
          75
        ]
      }
    },
    {
      "kind": "line",
