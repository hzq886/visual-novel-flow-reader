        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そうして、すぐに姉さんの心は深いところへ落ちた。",
        "それから『暗示』をかけていく。",
        "僕にとって、都合の良い『暗示』を。"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常３（昼）・室内着０１・催眠１",
        "body": "CH02B_03_01_006_01",
        "face": "CH02B_03_01_104_01",
