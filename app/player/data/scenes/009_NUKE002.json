      ]
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_009_NUKE002_003",
        "file": null
      },
      "lines": [
        "「ううん、私のことは気にしないで、先に帰って」"
      ]
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_009_NUKE002_004",
        "file": null
      },
      "lines": [
        "「悪いけれど、私は先に帰るわね。習い事があるし」"
      ]
    }
  ]
