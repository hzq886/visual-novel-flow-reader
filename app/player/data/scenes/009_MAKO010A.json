        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "了承してもらって喜び、急いで裸になる。"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
