    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_009_MAKO010A_004",
        "file": "voice/tuba_009_mako010A_004.ogg"
      },
      "lines": [
        "「教室で裸になっちゃって、もしも誰かに見られたら",
        "どうするつもり？　それとも見られたいの？」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
