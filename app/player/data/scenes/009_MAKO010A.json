        "face": "CH03B_02_02_104_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「見られても、いいです。見られたいです」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
      },
      "sprite": {
        "label": "翼（中）・通常２（夕）・制服０１・驚き１",
        "body": "CH03B_02_02_004_01",
        "face": "CH03B_02_02_104_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_009_MAKO010A_005",
        "file": "voice/tuba_009_mako010A_005.ogg"
      },
      "lines": [
        "「うんうん、そうだよね～？　マゾの変態だから、",
        "恥ずかしい格好を見られたいんだよね？」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
