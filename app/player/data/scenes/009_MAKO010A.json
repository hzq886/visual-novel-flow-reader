    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「そこをなんとか、お願いしますっ！」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
