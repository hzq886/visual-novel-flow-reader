        "offset": [
          331,
          70
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "僕は、土下座して頼み込む。"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
