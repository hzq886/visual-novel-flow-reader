        "face": "CH03B_03_02_101_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「気になるだろうけど、この指を見たらダメだよ。",
        "頭のてっぺんを意識したままでいるんだ」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・教室（夕）",
        "file": "BG16_92_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（夕）・制服０１・ポカン１",
