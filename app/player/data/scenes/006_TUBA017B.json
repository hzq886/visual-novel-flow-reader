        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "僕はベッドに横になる。",
        "そして、大きなお腹の彼女が跨ってきた。",
        "ずぶぶぶっ……。",
        "ゆっくりと、翼が挿入していく。"
      ],
      "bg": {
        "label": "#背景・和樹の部屋（夜）",
        "file": "BG03_03_00"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "voice": {
        "id": "TUBA_006_TUBA017B_001",
        "file": null
      },
      "lines": [
        "「ふぁぁぁ、チ×ポっ……オマ×コに入ってくるっ！",
        "ひ、ひさしぶりだよぉ」"
      ],
      "bg": {
        "label": "#EV072・目閉じ喘ぎ・裸",
        "file": "EV072_11"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "息を切らせながら、味わうように腰を落とす。",
        "膣孔の左右のヒダが、迎えるようにうごめいた。",
        "久しぶりのセックス。",
        "だが、期待からか、妊娠のせいか、既に膣孔は",
        "緩みぎみだった。",
        "勃起したモノは、すんなりと潜っていった。"
      ],
      "bg": {
        "label": "#EV072・目閉じ喘ぎ・裸",
        "file": "EV072_11"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "voice": {
        "id": "TUBA_006_TUBA017B_002",
        "file": null
      },
      "lines": [
        "「んっ、あ、あっ……あのカタチだぁっ……ふふっ、",
        "あん、懐かしいっ……あっはぁぁぁ……」"
      ],
      "bg": {
        "label": "#EV072・目閉じ喘ぎ・裸",
        "file": "EV072_11"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "包みこまれる、温かさと心地よさ。",
        "幸せな感覚に全身のチカラが抜けていくようだ。",
        "翼も同じようで、深く、長い呼吸をしている。"
      ],
      "bg": {
        "label": "#EV072・目閉じ喘ぎ・裸",
        "file": "EV072_11"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "voice": {
        "id": "TUBA_006_TUBA017B_003",
        "file": null
      },
      "lines": [
        "「はあぁっ……いちど、ぜんぶ……入れちゃうねっ、",
        "んぁっ、あふ……ふうぅぅっ……」"
      ],
      "bg": {
        "label": "#EV072・微笑み・裸",
        "file": "EV072_12"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "妊娠して、いくぶん膣内は柔らかくなった。",
        "しかし、緩くなったわけではない。",
        "中のヒダヒダがピッタリ張り付いてきて、",
        "密着感がすごかった。"
      ],
      "bg": {
        "label": "#EV072・微笑み・裸",
        "file": "EV072_12"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "voice": {
        "id": "TUBA_006_TUBA017B_004",
        "file": null
      },
      "lines": [
        "「きもちいいよぉ……んぁ、ああ、んっ、入ったぁ、",
        "おっきい……ふぁぁ……カタぁい……」"
      ],
      "bg": {
        "label": "#EV072・微笑み・裸",
        "file": "EV072_12"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "根元までゆっくりと挿入して、彼女は、ぶるるっと",
        "身を震わせた。",
        "根元から先っぽまで、温かな膣肉に包まれて、僕の",
        "ほうも思わずため息を吐いた。",
        "翼も、久しぶりのチ×ポに、蕩けた顔をしている。"
      ],
      "bg": {
        "label": "#EV072・微笑み・裸",
        "file": "EV072_12"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「お腹の赤ちゃんが心配だから、奥まで入れたり、",
        "激しく動かしたりないようにね？」"
      ],
      "bg": {
        "label": "#EV072・微笑み・裸",
        "file": "EV072_12"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "voice": {
        "id": "TUBA_006_TUBA017B_005",
        "file": null
      },
      "lines": [
        "「うん……それじゃあ、ゆっくりセックスするねっ！",
        "心配してくれて、うれしいなっ……」"
      ],
      "bg": {
        "label": "#EV072・微笑み・裸",
        "file": "EV072_12"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "微笑むと、翼は緩やかに腰を上下に動かしはじめた。",
        "ぬるぬるの膣肉が、モノを優しく撫でさする。",
        "モノ全体が温かくなるような、心地よさ。"
      ],
      "bg": {
        "label": "#EV072・微笑み・裸",
        "file": "EV072_12"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "voice": {
        "id": "TUBA_006_TUBA017B_006",
        "file": null
      },
      "lines": [
        "「んはぁっ、はぁっ……あっ……いいっ、んんんっ、",
        "この感じ……チ×ポで擦られる感じ、好き……」"
      ],
      "bg": {
        "label": "#EV072・目閉じ喘ぎ・裸・愛液",
        "file": "EV072_13"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "膣内は、たっぷりと濡れていた。",
        "ゆっくりとした抜き差しにも、ぬちゅ、ぬちゅ、と",
        "重たげな音が鳴る。",
        "翼は照れくさそうに笑った。"
      ],
      "bg": {
        "label": "#EV072・目閉じ喘ぎ・裸・愛液",
        "file": "EV072_13"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "voice": {
        "id": "TUBA_006_TUBA017B_007",
        "file": null
      },
      "lines": [
        "「恥ずかしいぐらい、音が鳴ってるねっ。久しぶりの",
        "セックス……んっ、すっごく楽しみだったから」"
      ],
      "bg": {
        "label": "#EV072・目閉じ喘ぎ・裸・愛液",
        "file": "EV072_13"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "膣肉はねっとりと絡むようになっていた。",
        "濡れた肉を押しのけるようにして、翼は",
        "一番深い部分まで腰を落としていく。",
        "胎児で膨らんだ子宮に押されてか、膣がちょっと",
        "浅くなったようだ。",
        "亀頭の先が、つんと膣奥に触れた。"
      ],
      "bg": {
        "label": "#EV072・目閉じ喘ぎ・裸・愛液",
        "file": "EV072_13"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "voice": {
        "id": "TUBA_006_TUBA017B_008",
        "file": null
      },
      "lines": [
        "「あふっ、んっ！　奥……当たっちゃった……」"
      ],
      "bg": {
        "label": "#EV072・目閉じ喘ぎ・裸・愛液",
        "file": "EV072_13"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "以前はコリコリしていた子宮口が、トロトロした",
        "柔らかさになっている。",
        "翼は慌てたように腰を持ちあげた。",
        "蕩けていた子宮口が、名残惜しげに吸いついてくる。"
      ],
      "bg": {
        "label": "#EV072・目閉じ喘ぎ・裸・愛液",
        "file": "EV072_13"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "voice": {
        "id": "TUBA_006_TUBA017B_009",
        "file": null
      },
      "lines": [
        "「奥は……危ないから……赤ちゃんが、いるものね。",
        "んんっ、もうちょっと、浅いところで、するね」"
      ],
      "bg": {
        "label": "#EV072・微笑み2・裸・愛液",
        "file": "EV072_14"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そう言って、膣奥に当たらないぐらいまでの深さで、",
        "出し入れをくりかえす。",
        "僕のほうは、それでも十分に気持ちよかった。",
        "むしろ、奥まで入れないことで、膣肉が引きこもうと",
        "吸いついてくるみたいだ。",
        "それに、精神的な満足感も強い。"
      ],
      "bg": {
        "label": "#EV072・微笑み2・裸・愛液",
        "file": "EV072_14"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
