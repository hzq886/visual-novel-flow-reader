        "face": "CH03B_01_01_103_01",
        "offset": [
          331,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「僕が乗ると、お腹に負担がかかっちゃいそうだし、",
        "翼に上になってもらったほうがいいかな」"
      ],
      "bg": {
        "label": "#背景・和樹の部屋（夜）",
