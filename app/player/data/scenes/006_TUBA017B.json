        "face": "CH03B_01_01_103_01",
        "offset": [
          331,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「そうだね、じゃあ、ボクが上になって跨るね！」"
      ],
      "bg": {
        "label": "#背景・和樹の部屋（夜）",
        "file": "BG03_03_00"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・妊娠０１・通常１",
        "body": "CH03B_02_01_005_01",
        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
