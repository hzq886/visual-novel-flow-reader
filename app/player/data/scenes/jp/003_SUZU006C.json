    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_003_SUZU006C_010",
        "file": "voice/suzu_003_suzu006C_010.ogg"
      },
      "lines": [
        "「もれりゅ、もれちゃうからぁ、ゆるひてぇっ！",
