    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_003_SUZU006C_011",
        "file": "voice/suzu_003_suzu006C_011.ogg"
      },
      "lines": [
        "「奥でイキたいのっ！　お願いっ、オマ×コの奥を、",
