    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「うふふ、処女喪失、おめでとう！　セックスって、",
        "素敵だったでしょう？」"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（夜）",
