      "voice": {
        "id": "MOBC_001_PRO002F_011",
        "file": "voice/mobc_001_pro002F_011.ogg"
      },
      "lines": [
        "「うあっ……あっ、あぁっ……」"
      ],
      "bg": {
        "label": "#背景・公園（昼）",
        "file": "BG18_01_00"
      },
      "sprite": {
        "label": "郡山（中）・通常１（昼）・スーツ０１・にっこり１",
