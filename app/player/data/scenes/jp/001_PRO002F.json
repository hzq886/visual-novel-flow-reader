        "face": "CH13B_01_01_102_01",
        "offset": [
          233,
          22
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "あのとき、サクライさんがしていたように、",
        "この男の心を深いところへ落とす。"
      ],
      "bg": {
        "label": "#背景・公園（昼）",
        "file": "BG18_01_00"
      },
      "sprite": {
        "label": "郡山（中）・通常１（昼）・スーツ０１・にっこり１",
        "body": "CH13B_01_01_001_01",
        "face": "CH13B_01_01_102_01",
        "offset": [
          233,
          22
        ]
      }
    },
    {
      "kind": "line",
      "who": "郡山　栄一",
      "lines": [
        "「あなたの心は沈んでいく。どんどん深いところへ",
        "落ちていく……この声だけが聞こえる」"
      ],
      "bg": {
        "label": "#背景・公園（昼）",
        "file": "BG18_01_00"
      },
      "sprite": {
        "label": "郡山（中）・通常１（昼）・スーツ０１・にっこり１",
        "body": "CH13B_01_01_001_01",
        "face": "CH13B_01_01_102_01",
        "offset": [
          233,
          22
        ]
      }
    },
    {
      "kind": "line",
      "who": "郡山　栄一",
      "voice": {
        "id": "MOBC_001_PRO002F_012",
        "file": "voice/mobc_001_pro002F_012.ogg"
      },
      "lines": [
        "「ふかい、ところ……どんどん……」"
      ],
      "bg": {
        "label": "#背景・公園（昼）",
        "file": "BG18_01_00"
      },
      "sprite": {
        "label": "郡山（中）・通常１（昼）・スーツ０１・催眠１",
