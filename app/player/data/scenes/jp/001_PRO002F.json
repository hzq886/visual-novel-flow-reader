        "face": "CH13B_01_01_199_01",
        "offset": [
          233,
          22
        ]
      }
    },
    {
      "kind": "line",
      "who": "郡山　栄一",
      "lines": [
        "「では、３つ数えたら、心は深いところから戻って、",
        "身体は動くようになります」"
      ],
      "bg": {
        "label": "#背景・公園（昼）",
        "file": "BG18_01_00"
      },
      "sprite": {
