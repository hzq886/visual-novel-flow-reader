      "voice": {
        "id": "TUBA_006_TUBA001B_012",
        "file": "voice/tuba_006_tuba001B_012.ogg"
      },
      "lines": [
        "「んんっ……んちゅ、ちゅっ……んふぁ、ちゅくっ」"
      ],
      "bg": {
        "label": "#EV010・虚ろ目眉寄せ2・キス",
        "file": "EV010_03"
      },
      "bgv": {
        "id": "BGV_TUBA_F001A",
        "file": "voice/BGV_tuba_f001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "流石に少し息苦しい。",
        "だけどそれも、翼とキスをしているんだと考えれば、",
        "段々と気持ちよさに変わっていく。"
      ],
      "bg": {
        "label": "#EV010・虚ろ目眉寄せ2・キス",
        "file": "EV010_03"
