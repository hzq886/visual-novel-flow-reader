      "voice": {
        "id": "TUBA_006_TUBA001B_017",
        "file": "voice/tuba_006_tuba001B_017.ogg"
      },
      "lines": [
        "「んはぁ……んちゅ、ちゅく、ちゅっ……んちゅ、",
        "ちゅっ、んんっ、ふぁ……んっちゅ、ちゅぷ」"
      ],
      "bg": {
        "label": "#EV010・虚ろ目眉寄せ2・キス",
