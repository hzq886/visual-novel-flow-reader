      "bg": {
        "label": "#EV010・虚ろ目うっとり・キス",
        "file": "EV010_04"
      },
      "bgv": {
        "id": "BGV_TUBA_F001A",
        "file": "voice/BGV_tuba_f001a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA001B_020",
        "file": "voice/tuba_006_tuba001B_020.ogg"
      },
      "lines": [
