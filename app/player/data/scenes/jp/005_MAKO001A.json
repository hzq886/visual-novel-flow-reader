          "code": "9001A",
          "file": "se/9001a.ogg"
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "パンッ！！"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・驚き１",
          "body": "CH04B_01_02_004_01",
