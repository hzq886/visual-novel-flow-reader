          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「それじゃあ、どけるよ」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
