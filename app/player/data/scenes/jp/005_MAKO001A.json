        "１つ、２つ……３つ！」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常３（夕）・制服０１・催眠１",
          "body": "CH04B_03_02_004_01",
          "face": "CH04B_03_02_104_01",
