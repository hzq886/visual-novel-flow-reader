          "offset": [
            238,
            128
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "そうして、教室に来てからの会話や、ゲームのことを",
        "忘れさせる。"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常３（夕）・制服０１・催眠１",
          "body": "CH04B_03_02_004_01",
          "face": "CH04B_03_02_104_01",
          "offset": [
            238,
            128
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「あなたは、古橋和樹と楠木翼が、男と女として",
        "仲良くなるのを、邪魔しません」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常３（夕）・制服０１・催眠１",
