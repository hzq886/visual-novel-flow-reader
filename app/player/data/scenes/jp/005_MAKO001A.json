          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「ちょっと残って、勉強をしてて。真琴のほうは、",
        "もう生徒会の仕事は終わったの？」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・呆れ１",
          "body": "CH04B_01_02_004_01",
          "face": "CH04B_01_02_107_01",
          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO001A_002",
        "file": "voice/mako_005_mako001A_002.ogg"
      },
      "lines": [
        "「ええ、終わったわ。この時期は、忙しくないから」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・微笑み１",
