          "face": "CH04B_03_02_103_01",
          "offset": [
            238,
            128
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "ゆっくりと、真琴が目を開ける。"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
