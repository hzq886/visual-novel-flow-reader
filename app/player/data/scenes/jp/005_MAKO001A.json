          "face": "CH04B_01_02_107_01",
          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「何か用事があるなら、先に帰ってもいいけれど？」"
