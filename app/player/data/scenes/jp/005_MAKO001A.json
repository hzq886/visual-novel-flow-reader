      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常２（夕）・制服０１・微笑み１",
          "body": "CH04B_02_02_004_01",
          "face": "CH04B_02_02_102_01",
          "offset": [
            238,
            135
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「さーて、宿題も終わったし……翼を待っている間、",
        "ヒマだからゲームでもしてみない？」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常２（夕）・制服０１・微笑み１",
