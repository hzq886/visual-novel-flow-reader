          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "それから彼女は、僕の顔を覗き込むようにして言う。"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・微笑み１",
          "body": "CH04B_01_02_004_01",
          "face": "CH04B_01_02_102_01",
          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO001A_026",
        "file": "voice/mako_005_mako001A_026.ogg"
      },
      "lines": [
        "「なんだか、疲れているみたいだけど、大丈夫？」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常２（夕）・制服０１・呆れ１",
          "body": "CH04B_02_02_004_01",
          "face": "CH04B_02_02_107_01",
          "offset": [
            238,
            135
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「そうだね……勉強を頑張り過ぎたかも……」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常２（夕）・制服０１・呆れ１",
          "body": "CH04B_02_02_004_01",
          "face": "CH04B_02_02_107_01",
          "offset": [
            238,
            135
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「翼は先に帰ったから、一緒に帰ろうか」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
