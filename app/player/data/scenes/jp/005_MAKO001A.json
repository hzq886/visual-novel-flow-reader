          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "それは嘘だった。",
        "真琴のことを、待っていたのだ。"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・驚き１",
