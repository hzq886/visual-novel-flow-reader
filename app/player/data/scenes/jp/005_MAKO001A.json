          "offset": [
            238,
            128
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "恋心を抱いていたとしても、封じさせてもらう。",
        "僕は、酷いことをしているだろうか？",
        "あまり深くは考えたくなかった。",
        "それから、３つ数えて覚ますことにする。"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常３（夕）・制服０１・催眠１",
          "body": "CH04B_03_02_004_01",
          "face": "CH04B_03_02_104_01",
          "offset": [
            238,
            128
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
