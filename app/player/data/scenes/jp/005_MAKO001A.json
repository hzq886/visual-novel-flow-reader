      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（大）・通常３（夕）・制服０１・催眠１",
          "body": "CH04C_03_02_004_01",
          "face": "CH04C_03_02_104_01",
          "offset": [
            475,
