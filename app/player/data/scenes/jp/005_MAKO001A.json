          "face": "CH04B_03_02_103_01",
          "offset": [
            238,
            128
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "真琴の身体から、力が抜けていく。"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常３（夕）・制服０１・眠り１",
          "body": "CH04B_03_02_004_01",
          "face": "CH04B_03_02_103_01",
          "offset": [
            238,
            128
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
