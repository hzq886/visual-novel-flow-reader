    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO001A_003",
        "file": "voice/mako_005_mako001A_003.ogg"
      },
      "lines": [
        "「えーっと、翼が来るまで、待っているの？」"
