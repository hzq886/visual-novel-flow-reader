          "offset": [
            238,
            135
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "彼女が興味を持つような言い方をしてみる。"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常２（夕）・制服０１・通常１",
          "body": "CH04B_02_02_004_01",
          "face": "CH04B_02_02_101_01",
          "offset": [
            238,
            135
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「これが得意な人は、テストとかの大事な場面でも、",
