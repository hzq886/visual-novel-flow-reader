          "face": "CH04B_01_02_104_01",
          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「真琴のほうは、もう生徒会の仕事は終わったの？」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
