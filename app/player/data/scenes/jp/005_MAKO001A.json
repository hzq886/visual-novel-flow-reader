    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO001A_025",
        "file": "voice/mako_005_mako001A_025.ogg"
      },
      "lines": [
        "「あっ、えっと……教室に一人で、どうしたの？」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・呆れ１",
