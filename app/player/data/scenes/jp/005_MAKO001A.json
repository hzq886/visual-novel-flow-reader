          "face": "CH04B_01_02_107_01",
          "offset": [
            235,
            150
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "僕がそう言うと、彼女は首を左右に振る。"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
