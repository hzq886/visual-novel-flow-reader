    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_005_MAKO001A_005",
        "file": "voice/tuba_005_mako001A_005.ogg"
      },
      "lines": [
        "「う、うーん……そういうものなのかな……？」"
