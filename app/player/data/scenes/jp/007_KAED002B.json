      "bg": {
        "label": "#EV038・微笑み",
        "file": "EV038_02"
      }
    },
    {
      "kind": "narration",
      "pages": [
        [
          "言うが早いか、楓さんは腰を振り始めた。"
        ],
        [
          "ゆっくりと全体をシゴくように、出し入れをする。"
        ]
