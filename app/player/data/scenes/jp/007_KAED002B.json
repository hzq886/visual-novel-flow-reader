      "bg": {
        "label": "#EV038・微笑み",
        "file": "EV038_02"
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_007_KAED002B_007",
        "file": "voice/kaed_007_kaed002B_007.ogg"
      },
      "lines": [
        "「それじゃあ、ゲームを始めましょう……頑張って、",
