    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_007_KAED002B_006",
        "file": "voice/kaed_007_kaed002B_006.ogg"
      },
      "lines": [
        "「うふふっ、奥まで入っちゃったわね。どうかしら？",
        "翼を産んだオマ×コの具合は……気持ちいい？」"
      ],
      "bg": {
        "label": "#EV038・微笑み",
        "file": "EV038_02"
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「す、すごく気持ちいいです」"
