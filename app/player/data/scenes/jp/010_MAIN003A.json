        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「それじゃあ、いこっか！」"
      ],
      "bg": {
        "label": "#背景・楠木家外観（昼）",
        "file": "BG07_01_00"
      },
