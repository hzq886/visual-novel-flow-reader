    {
      "kind": "line",
      "who": "古橋　綾菜",
      "lines": [
        "「うん、手伝いをしようと思って。あと、ちょっと",
        "頼みたいことがあるんだ」"
      ],
      "bg": {
        "label": "#背景・喫茶店（夕）",
        "file": "BG20_02_00"
      },
      "sprite": {
