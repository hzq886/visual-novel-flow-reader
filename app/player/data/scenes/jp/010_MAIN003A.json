    {
      "kind": "line",
      "who": "古橋　綾菜",
      "lines": [
        "「ええ、あるわよ。真琴ちゃん、好きだものね。",
        "明日中に食べてもらえるなら、大丈夫よ」"
      ],
      "bg": {
        "label": "#背景・喫茶店（夕）",
