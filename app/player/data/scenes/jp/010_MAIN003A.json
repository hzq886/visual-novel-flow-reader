      }
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "lines": [
        "「頼みたいこと？　なにかしら？」"
      ],
      "bg": {
        "label": "#背景・喫茶店（夕）",
        "file": "BG20_02_00"
      },
      "sprite": {
        "label": "綾菜（中）・通常１（夕）・私服０２・通常１",
