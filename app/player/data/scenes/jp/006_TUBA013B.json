        "face": "CH03C_01_02_104_02",
        "offset": [
          462,
          45
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「待って、翼！　どうしても翼に、言っておきたい",
        "ことがあるんだ！」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprite": {
        "label": "翼（大）・通常１（夕）・制服０１・驚き２",
        "body": "CH03C_01_02_004_01",
        "face": "CH03C_01_02_104_02",
        "offset": [
          462,
          45
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA013B_017",
        "file": "voice/tuba_006_tuba013B_017.ogg"
      },
      "lines": [
        "「ふぇっ！？　んあぁっ！　あっあっ、い、言って",
        "おきたいことって？　はっ、はぁんっ……」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprite": {
        "label": "翼（大）・通常２（夕）・制服０１・困り２",
