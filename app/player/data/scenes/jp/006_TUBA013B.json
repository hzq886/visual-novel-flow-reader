        "face": "CH03B_01_02_106_02",
        "offset": [
          331,
          70
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "分かっていて、あえて聞いてやる。",
        "もちろん、名前をわざと強調するのも忘れない。"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprite": {
        "label": "翼（中）・通常１（夕）・制服０１・悲しみ２",
        "body": "CH03B_01_02_004_01",
        "face": "CH03B_01_02_106_02",
        "offset": [
          331,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「もしかして、風邪でもひいてるの翼？　本当に無理",
        "しちゃダメだからね、翼？」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprite": {
        "label": "翼（中）・通常１（夕）・制服０１・悲しみ２",
        "body": "CH03B_01_02_004_01",
        "face": "CH03B_01_02_106_02",
        "offset": [
          331,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA013B_014",
        "file": "voice/tuba_006_tuba013B_014.ogg"
      },
      "lines": [
        "「んひゃうっ！　ち、違うのっ！　だっ、大丈夫っ！",
        "あっあっ！　な、なんでっ、ボクっ……！」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
