    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA013B_013",
        "file": "voice/tuba_006_tuba013B_013.ogg"
      },
      "lines": [
        "「ち、ちがっ、ふあぁんっ！　そんなんじゃなくて！",
