        "offset": [
          431,
          69
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「翼のことが本当に大切で、心から好きなんだ！」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprite": {
        "label": "翼（大）・通常２（夕）・制服０１・驚き２",
        "body": "CH03C_02_02_004_01",
        "face": "CH03C_02_02_104_02",
        "offset": [
          431,
          69
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA013B_019",
        "file": "voice/tuba_006_tuba013B_019.ogg"
      },
      "lines": [
        "「あくぅぅっ！？　あぐっ、んひっ、くふぅぅっ！」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprite": {
        "label": "翼（大）・通常１（夕）・制服０１・うっとり１",
