    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "KAED_007_KAED003A_009",
        "file": "voice/kaed_007_kaed003A_009.ogg"
      },
      "lines": [
        "「性教育って大切だと思うのだけど、お姉さんたちに",
        "そういうコトは教わっていないでしょう？」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・私服０１・呆れ１",
