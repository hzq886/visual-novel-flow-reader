        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "さっきの『暗示』の中では、僕の両親に関しては",
        "特に言及していない。",
        "娘の友人に『性教育をしなくてはいけない』という、",
        "異常ともいえる思考。",
        "それに理由付けをするために、彼女の心の中で、",
        "自然と発生したものだろう。"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・私服０１・悲しみ１",
        "body": "CH05B_01_01_003_01",
        "face": "CH05B_01_01_106_01",
        "offset": [
