      "voice": {
        "id": "KAED_007_KAED003A_010",
        "file": "voice/kaed_007_kaed003A_010.ogg"
      },
      "lines": [
        "「だから私が代わりに、色々と教えてあげたいの。",
        "嫌じゃなければ、だけど……」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
