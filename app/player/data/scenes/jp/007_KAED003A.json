        "face": "CH05B_01_01_101_01",
        "offset": [
          234,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「いえ、嬉しいです！　ぜひ教えてください！」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
