          234,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「そうですね、姉さんたちには教わってないです」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・私服０１・呆れ１",
        "body": "CH05B_01_01_003_01",
        "face": "CH05B_01_01_107_01",
        "offset": [
