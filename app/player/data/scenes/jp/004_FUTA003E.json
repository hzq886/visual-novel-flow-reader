      },
      "bgv": {
        "id": "BGV_SUZU_F002A",
        "file": "voice/BGV_suzu_f002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_004_FUTA003E_022",
        "file": "voice/suzu_004_futa003E_022.ogg"
      },
      "lines": [
        "「んっふ、ふう、ちゅーちゅー！　ちゅぷぷっ！",
