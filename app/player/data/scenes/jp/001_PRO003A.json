{
  "code": "001_PRO003A",
  "route": "001",
  "locale": "jp",
  "beats": [
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_001",
        "file": "voice/ayan_001_pro003A_001.ogg"
      },
      "lines": [
        "「おはよう。今朝は早いのね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_002",
        "file": "voice/ayan_001_pro003A_002.ogg"
      },
      "lines": [
        "「おはよう。お休みの日なのに、早いのね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_003",
        "file": "voice/ayan_001_pro003A_003.ogg"
      },
      "lines": [
        "「あら、眠そうね……大丈夫？」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_004",
        "file": "voice/ayan_001_pro003A_004.ogg"
      },
      "lines": [
        "「はい、朝食の準備が出来たわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_005",
        "file": "voice/ayan_001_pro003A_005.ogg"
      },
      "lines": [
        "「今日は、スクランブル・エッグにしたみたわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_006",
        "file": "voice/ayan_001_pro003A_006.ogg"
      },
      "lines": [
        "「育ちざかりなんだから、たくさん食べてね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_007",
        "file": "voice/ayan_001_pro003A_007.ogg"
      },
      "lines": [
        "「今日は午後からお天気が崩れるみたいよ？",
        "傘を忘れないで持って行ってね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_008",
        "file": "voice/ayan_001_pro003A_008.ogg"
      },
      "lines": [
        "「はい、お弁当。残さず食べてくれると嬉しいわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_009",
        "file": "voice/ayan_001_pro003A_009.ogg"
      },
      "lines": [
        "「いってらっしゃい。事故には気を付けてね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_010",
        "file": "voice/ayan_001_pro003A_010.ogg"
      },
      "lines": [
        "「そろそろ、私も出るから……」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_011",
        "file": "voice/ayan_001_pro003A_011.ogg"
      },
      "lines": [
        "「いらっしゃいませ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_012",
        "file": "voice/ayan_001_pro003A_012.ogg"
      },
      "lines": [
        "「ありがとうございました」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_013",
        "file": "voice/ayan_001_pro003A_013.ogg"
      },
      "lines": [
        "「あら、いらっしゃい。三人揃って来るのは、",
        "久しぶりね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_014",
        "file": "voice/ayan_001_pro003A_014.ogg"
      },
      "lines": [
        "「はーい、ご注文は、お決まりでしょうか？」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_015",
        "file": "voice/ayan_001_pro003A_015.ogg"
      },
      "lines": [
        "「はい、どうぞ。ゆっくりしていってね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_016",
        "file": "voice/ayan_001_pro003A_016.ogg"
      },
      "lines": [
        "「手伝ってくれて、ありがとう」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_017",
        "file": "voice/ayan_001_pro003A_017.ogg"
      },
      "lines": [
        "「それじゃあ、先に帰っていてね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_018",
        "file": "voice/ayan_001_pro003A_018.ogg"
      },
      "lines": [
        "「お帰りなさい。遅かったのね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_019",
        "file": "voice/ayan_001_pro003A_019.ogg"
      },
      "lines": [
        "「お帰りなさい。お仕事、お疲れ様」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_020",
        "file": "voice/ayan_001_pro003A_020.ogg"
      },
      "lines": [
        "「もう、夕食の準備は出来てるわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_021",
        "file": "voice/ayan_001_pro003A_021.ogg"
      },
      "lines": [
        "「ちょっと、作り過ぎちゃったかしら？」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_022",
        "file": "voice/ayan_001_pro003A_022.ogg"
      },
      "lines": [
        "「ふふっ、そう言ってもらえると、嬉しいわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_023",
        "file": "voice/ayan_001_pro003A_023.ogg"
      },
      "lines": [
        "「いつもありがとう。助かるわ」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_024",
        "file": "voice/ayan_001_pro003A_024.ogg"
      },
      "lines": [
        "「先にお風呂に入ったら？」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_025",
        "file": "voice/ayan_001_pro003A_025.ogg"
      },
      "lines": [
        "「洗濯物、カゴに入れておいてね」"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_026",
        "file": "voice/ayan_001_pro003A_026.ogg"
      },
      "lines": [
        "「おやすみなさい。ゆっくり休んでね」"
      ]
    }
  ],
  "bgm": {
    "track": "M01",
    "file": "bgm/M01.ogg"
  }
}
