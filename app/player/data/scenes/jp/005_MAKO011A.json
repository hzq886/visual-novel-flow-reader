      "voice": {
        "id": "SUZU_005_MAKO011A_001",
        "file": "voice/suzu_005_mako011A_001.ogg"
      },
      "lines": [
        "「働かないで食べるエサは、美味しいかしら？",
        "ほら、床を汚すんじゃないわよ？」"
