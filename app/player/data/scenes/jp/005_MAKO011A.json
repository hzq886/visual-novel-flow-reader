      "voice": {
        "id": "AYAN_005_MAKO011A_001",
        "file": "voice/ayan_005_mako011A_001.ogg"
      },
      "lines": [
        "「食事が済んだら、いつものアレをしましょうか。",
        "ケツ穴を綺麗にしておいてね？」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・古橋家リビング（夜）",
