        "face": "CH01B_01_01_102_01",
        "offset": [
          426,
          73
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「はいっ、分かりました。綺麗にしておきます」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・古橋家リビング（夜）",
        "file": "BG02_93_00"
      },
