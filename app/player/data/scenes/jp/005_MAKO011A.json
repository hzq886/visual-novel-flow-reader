      "bg": {
        "label": "#背景・アイキャッチ・古橋家リビング（夜）",
        "file": "BG02_93_00"
      },
      "sprite": {
        "label": "綾菜（中）・通常２（昼）・私服０１・にっこり１",
        "body": "CH01B_02_01_003_01",
        "face": "CH01B_02_01_102_01",
        "offset": [
          431,
          78
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "いつからそうなったのかは思い出せないけれど、",
        "僕は変態のマゾなのだ。",
        "姉さんたちは、それを理解して、こうやって",
        "僕をしっかりと躾けてくれる。"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・古橋家リビング（夜）",
        "file": "BG02_93_00"
      },
      "sprite": {
        "label": "綾菜（中）・通常２（昼）・私服０１・にっこり１",
