      "voice": {
        "id": "SUZU_005_MAKO011A_004",
        "file": "voice/suzu_005_mako011A_004.ogg"
      },
      "lines": [
        "「あら、気にしなくていいのよ。こいつは、こうして",
        "イジメられると喜ぶ、変態なんだから！」"
