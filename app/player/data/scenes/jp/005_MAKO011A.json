        "offset": [
          238,
          76
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "涼姉の言う通りだった。",
        "イジメてもらえると、すごく嬉しい。"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・古橋家リビング（夜）",
        "file": "BG02_93_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常２（昼）・室内着０１・怒り１",
        "body": "CH02B_02_01_006_01",
        "face": "CH02B_02_01_105_01",
        "offset": [
