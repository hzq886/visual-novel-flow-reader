    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_006_TUBA020A_002",
        "file": "voice/mako_006_tuba020A_002.ogg"
      },
      "lines": [
        "「ふぁむっ……んんっ、んむっ、じゅるるっ……」"
