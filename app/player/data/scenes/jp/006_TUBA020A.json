        "id": "BGV_MAKO_F002A",
        "file": "voice/BGV_mako_f002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「夜、お風呂に入って綺麗にしたら、翼のおクチで",
