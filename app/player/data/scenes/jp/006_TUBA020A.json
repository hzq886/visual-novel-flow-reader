      "bgv": {
        "id": "BGV_MAKO_F002A",
        "file": "voice/BGV_mako_f002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「洗ってないし、かなり汚いから、メイドに任せた",
        "ほうがいいよ。病気にでもなったら大変だし」"
      ],
      "bg": {
        "label": "#EV087・悲しみ・微笑み・にっこり",
        "file": "EV087_02"
      },
      "bgv": {
        "id": "BGV_MAKO_F002A",
        "file": "voice/BGV_mako_f002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
