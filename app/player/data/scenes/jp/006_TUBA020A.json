    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_006_TUBA020A_004",
        "file": "voice/mako_006_tuba020A_004.ogg"
      },
      "lines": [
        "「んれろぉっ、れろおぉっ……んんんぅ、んんふっ、",
