    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_008_TUBA008C_029",
        "file": "voice/kaed_008_tuba008C_029.ogg"
      },
      "lines": [
        "「でてるっ、あついの、すっごいっ、あああぁ！」"
      ],
      "bg": {
        "label": "#EV078・困り笑い・軽くアヘ・うっとり蕩け・楓挿入・萎え・精液",
        "file": "EV078_12"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "楓さんの腰が、ビクンビクンと震える。",
        "僕はその子宮に、しっかりと注ぎ込んだ。"
      ],
      "bg": {
        "label": "#EV078・困り笑い・軽くアヘ・うっとり蕩け・楓挿入・萎え・精液",
        "file": "EV078_12"
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_008_TUBA008C_030",
        "file": "voice/kaed_008_tuba008C_030.ogg"
      },
      "lines": [
        "「んんっ、ふあぁぁ……はぁっ、はぁっ……んあっ！",
        "んふぅ……すごかったぁ……」"
      ],
      "bg": {
        "label": "#EV078・困り笑い・軽くアヘ・微笑み2・楓挿入・萎え・精液",
        "file": "EV078_13"
