        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA005B_024",
        "file": "voice/tuba_006_tuba005B_024.ogg"
      },
      "lines": [
        "「前の勝負のときも、口の奥に舌を入れたものねっ！",
        "オチ×チンも、オマ×コの奥に入れていいよ！」"
      ],
      "bg": {
        "label": "#EV036・うっとり・見つめ・宛がい・愛液",
        "file": "EV036_05"
      },
      "sprite": {
