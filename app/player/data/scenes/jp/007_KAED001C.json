          "offset": [
            232,
            64
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "そうやって、ベッドで寝てしまったことにしておく。"
      ],
      "bg": {
        "label": "#背景・楠木夫婦の寝室（昼）",
        "file": "BG10_01_00"
      },
      "sprites": [
        {
