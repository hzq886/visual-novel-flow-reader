          "offset": [
            232,
            64
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「ドアが閉じる音がしたら、いつもの心の状態に",
        "戻りますよ……和樹くんは帰ったと思います」"
