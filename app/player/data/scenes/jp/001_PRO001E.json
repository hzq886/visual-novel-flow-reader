        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「いや、あそんだらダメだよ……べんきょうしないと",
        "まことちゃんが、おこられるとおもうし……」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
