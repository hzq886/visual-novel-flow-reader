    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO001E_015",
        "file": "voice/tuba_001_pro001E_015.ogg"
      },
      "lines": [
        "「なんだよそれっ！　ふりょーって、そーゆー",
        "言いかたは、ないだろっ！」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
        "file": "BG11_11_00"
      },
      "sprite": {
        "label": "旧早紀（中）・通常１（昼）・スーツ０１・驚き１",
        "body": "CH26B_01_01_001_01",
        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "翼は、男の子みたいに、そう叫んだ。",
        "よほど怒ったのか、女の子らしくなると決めたのも、",
        "忘れてしまったみたいだ。",
        "そのせいでまた、にらまれる。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
        "file": "BG11_11_00"
      },
      "sprite": {
        "label": "旧早紀（中）・通常１（昼）・スーツ０１・驚き１",
        "body": "CH26B_01_01_001_01",
        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_001_PRO001E_008",
        "file": "voice/saki_001_pro001E_008.ogg"
      },
      "lines": [
        "「ほら！　ウチの真琴が、あなたみたいな、乱暴な",
        "言葉づかいの女の子になったら、どうするの！？」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
        "file": "BG11_11_00"
      },
      "sprite": {
        "label": "旧早紀（中）・通常１（昼）・スーツ０１・驚き１",
        "body": "CH26B_01_01_001_01",
        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "どんどん、口ゲンカみたいになっていく。",
        "このままだとダメだ。",
        "どうにかしないと……。",
        "僕は、思い切って話しかける。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
        "file": "BG11_11_00"
      },
      "sprite": {
        "label": "旧早紀（中）・通常１（昼）・スーツ０１・驚き１",
        "body": "CH26B_01_01_001_01",
        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「あのっ！　あそびじゃなくて、べんきょうなら、",
        "いいですか？　べんきょうかいをするなら」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
        "file": "BG11_11_00"
      },
      "sprite": {
        "label": "旧早紀（中）・通常１（昼）・スーツ０１・驚き１",
        "body": "CH26B_01_01_001_01",
        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "真琴ちゃんのお母さんは、眉をひそめた。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
        "file": "BG11_11_00"
      },
      "sprite": {
        "label": "旧早紀（中）・通常１（昼）・スーツ０１・驚き１",
        "body": "CH26B_01_01_001_01",
        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_001_PRO001E_009",
        "file": "voice/saki_001_pro001E_009.ogg"
      },
      "lines": [
        "「勉強会？　そんなことをしなくても、ウチの真琴は",
        "塾に行って勉強してるわ」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
        "file": "BG11_11_00"
      },
      "sprite": {
        "label": "旧早紀（中）・通常１（昼）・スーツ０１・驚き１",
        "body": "CH26B_01_01_001_01",
        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "もちろん、そういう風に言われるとは分かっていた。",
        "だけど、あきらめない。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
        "file": "BG11_11_00"
      },
      "sprite": {
        "label": "旧早紀（中）・通常１（昼）・スーツ０１・驚き１",
        "body": "CH26B_01_01_001_01",
        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「ウチのお姉ちゃんは、すごくあたまがいいので、",
        "おしえてもらうと、その、おとくかなって」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
        "file": "BG11_11_00"
      },
      "sprite": {
        "label": "旧早紀（中）・通常１（昼）・スーツ０１・驚き１",
        "body": "CH26B_01_01_001_01",
        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_001_PRO001E_010",
        "file": "voice/saki_001_pro001E_010.ogg"
      },
      "lines": [
