        "offset": [
          125,
          300
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「うん、やったね！　すごくうれしいよ！」"
      ],
      "bg": {
        "label": "#背景・幼少時教室（幼少）",
        "file": "BG24_11_00"
