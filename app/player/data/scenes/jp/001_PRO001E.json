        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_001_PRO001E_007",
        "file": "voice/saki_001_pro001E_007.ogg"
      },
      "lines": [
        "「それに、あなたたちと遊ばせて、不良にでも",
        "なってしまったら困るわ」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
        "file": "BG11_11_00"
      },
      "sprite": {
        "label": "旧早紀（中）・通常１（昼）・スーツ０１・驚き１",
        "body": "CH26B_01_01_001_01",
        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "さすがにそれは、ひどい決めつけだと思う。"
