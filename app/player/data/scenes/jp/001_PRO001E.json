      "voice": {
        "id": "SAKI_001_PRO001E_006",
        "file": "voice/saki_001_pro001E_006.ogg"
      },
      "lines": [
        "「この子は、しっかりした、立派な大人にならないと",
        "いけないの。遊んでいるヒマはないのよ」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
