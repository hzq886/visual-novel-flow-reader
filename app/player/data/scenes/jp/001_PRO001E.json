        "face": "CH26B_01_01_104_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO001E_016",
        "file": "voice/tuba_001_pro001E_016.ogg"
      },
      "lines": [
        "「やったねっ！　あのお母さんに、オッケーして",
        "もらうなんて、カズはすごいなー！」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（幼少・昼）",
