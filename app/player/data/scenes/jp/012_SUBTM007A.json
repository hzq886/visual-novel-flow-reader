    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「ちょっと用事があるから、今日は先に帰っていて",
        "もらえるかな？」"
      ],
      "bg": {
        "label": "#背景・黒一色",
        "file": "BG_BLACK"
