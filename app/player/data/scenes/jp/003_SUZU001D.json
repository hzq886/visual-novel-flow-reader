    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_003_SUZU001D_004",
        "file": "voice/suzu_003_suzu001D_004.ogg"
      },
      "lines": [
        "「そういうあなたは、したことあるの？」"
