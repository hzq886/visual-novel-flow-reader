    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_003_SUZU001D_001",
        "file": "voice/suzu_003_suzu001D_001.ogg"
      },
      "lines": [
        "「ええ、ものすごく気持ちいいわよ。ちょっと",
        "刺激は強いけれどね」"
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "そしてクリトリスを見せつけながら、説明をする。"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_003_SUZU001D_002",
        "file": "voice/suzu_003_suzu001D_002.ogg"
      },
      "lines": [
        "「いったん触り始めると、夢中になってしまって、",
        "止められなくなるくらい、気持ちいいの」"
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "なんとなく、姉さんの頬が染まっている気がする。",
        "その快感を、思い出しているのだろうか。"
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「ということは……その、涼姉もオナニーとかを",
        "したことがあるんだよね？」"
