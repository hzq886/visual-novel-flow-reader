    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_003_SUZU001D_005",
        "file": "voice/suzu_003_suzu001D_005.ogg"
      },
      "lines": [
        "「もう子供じゃないって、分かってはいるけれど、",
        "オナニーをするようになっていたなんてね」"
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "僕だって、姉さんたちがオナニーをしていたなんて、",
