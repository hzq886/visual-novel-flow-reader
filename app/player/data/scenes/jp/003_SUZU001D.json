    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_003_SUZU001D_003",
        "file": "voice/suzu_003_suzu001D_003.ogg"
      },
      "lines": [
        "「もちろんよ。女にも性欲はあるんだから」"
