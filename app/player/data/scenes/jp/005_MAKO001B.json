    {
      "kind": "narration",
      "lines": [
        "すました顔で僕を非難しているが、エッチに興味が",
        "あるのは、男も女も変わらないはずだ。"
      ],
      "sprite": {
        "label": "真琴（中）・通常３（夕）・制服０１・催眠１",
        "body": "CH04B_03_02_004_01",
        "face": "CH04B_03_02_104_01",
        "offset": [
          238,
