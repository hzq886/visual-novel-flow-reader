        "face": "CH04B_01_01_106_01",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "lines": [
        "「泣けば……許してもらえると思ってる？」"
      ],
      "bg": {
        "label": "#背景・カメラ・真琴・排便",
        "file": "BG12_01_91"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・裸０１・悲しみ１",
