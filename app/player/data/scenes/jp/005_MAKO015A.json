    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO015A_003",
        "file": "voice/mako_005_mako015A_003.ogg"
      },
      "lines": [
        "「そうすれば、私にも和樹と付き合うチャンスが、",
        "あるかもしれないって、思って……」"
      ],
      "bg": {
        "label": "#背景・カメラ・真琴・排便",
        "file": "BG12_01_91"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・裸０１・悲しみ１",
        "body": "CH04B_01_01_001_01",
        "face": "CH04B_01_01_106_01",
        "offset": [
