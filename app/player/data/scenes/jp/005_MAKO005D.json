          135
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "早紀さんは、自分の下腹部に、視線を落とす。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・下着０１・うっとり１",
        "body": "CH04B_02_01_002_01",
        "face": "CH04B_02_01_103_01",
        "offset": [
          238,
          135
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_002",
        "file": "voice/saki_005_mako005D_002.ogg"
      },
      "lines": [
        "「お腹いっぱい食べたから、出したくなってきたわ。",
        "もちろん、協力してくれるわよね？」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・下着１１・微笑み１",
        "body": "CH06B_01_01_002_11",
        "face": "CH06B_01_01_103_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "その言葉に、真琴が眉をひそめた。",
        "不穏な空気を感じ取ったのだろう。",
        "早紀さんは、相変わらず真面目な顔をしながら、",
        "僕に説明する。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・下着０１・怒り１",
        "body": "CH04B_02_01_002_01",
        "face": "CH04B_02_01_105_01",
        "offset": [
          238,
          135
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_003",
        "file": "voice/saki_005_mako005D_003.ogg"
      },
      "lines": [
        "「我が家に男性がいるときは、排尿、排便する姿を",
        "観察してもらうことになっているの」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・下着１１・通常１",
        "body": "CH06B_01_01_002_11",
        "face": "CH06B_01_01_101_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO005D_001",
        "file": "voice/mako_005_mako005D_001.ogg"
      },
      "lines": [
        "「まさかっ……う、嘘でしょう！？　そんなことを",
        "ママにやらせるつもり！？」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・下着０１・驚き２",
        "body": "CH04B_01_01_002_01",
        "face": "CH04B_01_01_104_02",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "真琴が驚き惑う様子を見るのは、最高の気分だ。",
        "やはり、早紀さんに催眠術をかけて良かった。",
        "慌てふためく娘をよそに、彼女はリビングの端に",
        "置いてあったダンボール箱に近寄る。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・下着０１・驚き２",
        "body": "CH04B_01_01_002_01",
        "face": "CH04B_01_01_104_02",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そして、そこから取り出したのは、おまるだった。"
      ],
      "bg": {
        "label": "ITEM_07_01",
        "file": "ITEM_07_01"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_004",
        "file": "voice/saki_005_mako005D_004.ogg"
      },
      "lines": [
        "「仕事帰りに買っておいたの。トイレでするより、",
        "このほうが見やすいでしょう？」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・下着０１・通常１",
        "body": "CH06B_01_01_002_01",
        "face": "CH06B_01_01_101_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "それもすべて、僕の『暗示』による指示だ。",
        "真琴は愕然としたまま、おまるを見ている。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・下着０１・通常１",
        "body": "CH06B_01_01_002_01",
        "face": "CH06B_01_01_101_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_005",
        "file": "voice/saki_005_mako005D_005.ogg"
      },
      "lines": [
        "「さっそく使うことになるとは、思わなかったわ。",
        "男性が来ることなんて、めったにないから」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・下着０１・通常１",
        "body": "CH06B_01_01_002_01",
        "face": "CH06B_01_01_101_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "使わせるつもりで、それを購入してもらったのだ。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・下着０１・通常１",
        "body": "CH06B_01_01_002_01",
        "face": "CH06B_01_01_101_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_006",
        "file": "voice/saki_005_mako005D_006.ogg"
      },
      "lines": [
        "「そうそう、トイレットペーパーが無いわね。",
        "真琴、持ってきてくれる？」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "早紀（中）・通常１（昼）・下着０１・微笑み１",
        "body": "CH06B_01_01_002_01",
        "face": "CH06B_01_01_103_01",
        "offset": [
          265,
          60
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO005D_002",
        "file": "voice/mako_005_mako005D_002.ogg"
      },
      "lines": [
        "「は、はい……分かりました。取ってきます」"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・下着０１・悲しみ１",
        "body": "CH04B_02_01_002_01",
        "face": "CH04B_02_01_106_01",
        "offset": [
          238,
          135
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "さすがに拭かないわけにもいかないから、",
        "紙は必要だろう。",
        "真琴は、トイレに向かった。"
      ],
      "bg": {
        "label": "#背景・望月家リビング（夜）",
        "file": "BG11_03_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・下着０１・悲しみ１",
        "body": "CH04B_02_01_002_01",
        "face": "CH04B_02_01_106_01",
        "offset": [
          238,
          135
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "母親の股間を拭くための紙を取りに……。",
        "………。",
        "……。",
        "…。",
        "娘が戻ってくると、早紀さんは指示をする。"
      ],
      "bg": {
        "label": "#背景・黒一色",
        "file": "BG_BLACK"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_007",
        "file": "voice/saki_005_mako005D_007.ogg"
      },
      "lines": [
        "「真琴は、私の後ろのほうに座って、終わったら",
        "拭いてちょうだい」"
      ],
      "bg": {
        "label": "#背景・黒一色",
        "file": "BG_BLACK"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そして、ショーツを脱いで、おまるに跨った。"
      ],
      "bg": {
        "label": "#背景・黒一色",
        "file": "BG_BLACK"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "こんな母親の姿なんて、見たくないだろう。",
        "だけど真琴は、従うことしか出来ない。",
        "それにしても、大人の女性がおまるに跨る姿は、",
        "なかなかインパクトがある。",
        "オマ×コ丸出しの、ものすごい格好だ。"
      ],
      "bg": {
        "label": "#EV051・悔しい・真面目顔",
        "file": "EV051_01"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_008",
        "file": "voice/saki_005_mako005D_008.ogg"
      },
      "lines": [
        "「それじゃあ、排泄をするわよ？　特に私の股間を、",
        "しっかりと見ていてね」"
      ],
      "bg": {
        "label": "#EV051・悔しい・真面目顔",
        "file": "EV051_01"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "言われなくとも、凝視してしまう。",
        "さっき出したばかりだというのに、僕のモノは、",
        "ガチガチになっていた。",
        "でも、元々の性格のせいか、少し言い方が堅い。",
        "そう思った僕は、導入のキーワードを言った。"
      ],
      "bg": {
        "label": "#EV051・悔しい・真面目顔",
        "file": "EV051_01"
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「『厳しいポニーテール』」"
      ],
      "bg": {
        "label": "#EV051・悔しい・真面目顔",
        "file": "EV051_01"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_009",
        "file": "voice/saki_005_mako005D_009.ogg"
      },
      "lines": [
        "「うあっ！？　あっ、うっ……はあぁぁっ……」"
      ],
      "bg": {
        "label": "#EV051・悔しい・真面目顔",
        "file": "EV051_01"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "すぐに早紀さんの心は、深いところへ落ちた。",
        "大きく股を開いて、性器を見せたままで。"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「いいですか、早紀さん。あなたは排尿のことを、",
        "しょんべんと言います」"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_010",
        "file": "voice/saki_005_mako005D_010.ogg"
      },
      "lines": [
        "「はいにょうのこと……しょんべんといいます」"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "その『暗示』に、真琴が再び驚く。"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO005D_003",
        "file": "voice/mako_005_mako005D_003.ogg"
      },
      "lines": [
        "「なっ、なんて馬鹿なコトを言わせるのよっ！？",
        "この変態！　品性下劣男っ！」"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "その罵声を無視して、僕は言葉を続ける。",
        "真琴にキーワードも聞かれているが、どうせ邪魔は",
        "出来ないのだ。"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「そして排便のことは、ウンコと言いますよ」"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_011",
        "file": "voice/saki_005_mako005D_011.ogg"
      },
      "lines": [
        "「はいべん……うんこといいます……」"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "これで、いいだろう。"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「３つ数えると、いつもの心の状態に戻ります。",
        "１つ、２つ……３つ！」"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      },
      "se": [
        {
          "code": "9001A",
          "file": "se/9001a.ogg"
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "パンッ！！",
        "手を叩くと、ハッとして僕のほうを見つめる。"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      },
      "flash": 1
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_012",
        "file": "voice/saki_005_mako005D_012.ogg"
      },
      "lines": [
        "「えっと……まずはしょんべんをするから、しっかり",
        "見ていてちょうだい」"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そう言って、早紀さんはおまるの上でふんばりだす。",
        "スベスベの内腿にチカラが入り、ガーターベルトに",
        "飾られた柔らかそうな下腹がきゅっと引っ込む。",
        "大きく開かれた脚の間、濃い目のヘアーの下の",
        "赤い割れ目がヒクヒクしている。"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_013",
        "file": "voice/saki_005_mako005D_013.ogg"
      },
      "lines": [
        "「しょんべんは、あんまり我慢できないほうだから、",
        "すぐに出ると思うのよ」"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "女の方が、男よりも頻繁にトイレに行くイメージだ。"
      ],
      "bg": {
        "label": "#EV051・悔しい・催眠",
        "file": "EV051_02"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "早紀さんは何度か眉を寄せ、りきんで見せた。",
        "眉がキリリとして、颯爽とした雰囲気がさらに",
        "強くなるが……おまるの上なのが笑えてくる。"
      ],
      "bg": {
        "label": "#EV051・悔しい・眉寄せ",
        "file": "EV051_03"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_014",
        "file": "voice/saki_005_mako005D_014.ogg"
      },
      "lines": [
        "「んんっ……すぐに出るからっ……うっ、んはっ、",
        "もう出るっ！　しょんべん出るから見てっ！」"
      ],
      "bg": {
        "label": "#EV051・悔しい・眉寄せ",
        "file": "EV051_03"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "その言葉が終わると同時に、割れ目の間から、",
        "ちょろちょろっと液体が溢れでてきた。",
        "透明のおしっこは、股間を濡らすように垂れて、",
        "すぐに勢いよく飛び出した。"
      ],
      "bg": {
        "label": "#EV051・悔しい・眉寄せ",
        "file": "EV051_03"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "ちょろっ……じょろじょろじょろっ……。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      },
      "se": [
        {
          "code": "8412A",
          "file": "se/8412a.ogg"
        }
      ]
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_015",
        "file": "voice/saki_005_mako005D_015.ogg"
      },
      "lines": [
        "「んはぁっ、出たぁっ……んんんっ、見てぇ！　私の",
        "しょんべんっ！　じょろじょろ出てるからぁ！」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "股間からおしっこを噴きだしながら、嬉しそうに言う",
        "早紀さん。",
        "その後ろで、真琴は悲しそうな顔でその言葉を",
        "聞いている。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO005D_004",
        "file": "voice/mako_005_mako005D_004.ogg"
      },
      "lines": [
        "「ううっ……どうしてママまで巻き込むのよっ！",
        "こんな、こんな最低男のせいで、ママが……」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "からっぽのおまるの中に、放物線を描きながら",
        "落ちていくおしっこ。",
        "おまるを叩くパタパタ、じょろじょろという音が、",
        "早紀さんに似合わないほど下品だった。",
        "だが、早紀さんは気にしたふうもない。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_016",
        "file": "voice/saki_005_mako005D_016.ogg"
      },
      "lines": [
        "「はぁぁっ……ふうっ、んっはぁっ……はあぁっ」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "リラックスした様子で溜息をつきながら、勢いよく",
        "おしっこを飛ばしている。",
        "出している間も、股間にチカラが入っているのか、",
        "開いた内腿がヒクヒクしている。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_017",
        "file": "voice/saki_005_mako005D_017.ogg"
      },
      "lines": [
        "「本当はご飯中にしたかったのよ。我慢していた分、",
        "しょんべんするの気持ちいいわぁ！」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "まるで、見せつけるように股間をグッと突きだす。",
        "ぱっくり開いた割れ目の間から、おしっこが出ている",
        "様子が丸見えだ。",
        "おしっこの出る角度が変わったせいか、おまるに",
        "落ちる音がいっそう派手になった。",
        "早紀さんはぶるっと身体を震わせた。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_018",
        "file": "voice/saki_005_mako005D_018.ogg"
      },
      "lines": [
        "「ん、んんっ……んはぁ、ふああぁっ……なんだか、",
        "見ていてもらうと、ゾクゾクするわね」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "もしかして、マゾの素質があるのかな？",
        "カッコイイ早紀さんみたいな人に、マゾっ気が",
        "あったとしたら、最高だ。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_019",
        "file": "voice/saki_005_mako005D_019.ogg"
      },
      "lines": [
        "「はぁーっ……いっぱいしょんべん出てるわぁっ！",
        "んはぁぁっ……はぁーっ……」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "かなり長いおしっこだった。",
        "どうやら、しっかりため込んでいたみたいだ。",
        "仕事中、トイレを我慢する癖でもついてるのかも",
        "しれない。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_020",
        "file": "voice/saki_005_mako005D_020.ogg"
      },
      "lines": [
        "「んっふ……しょんべんをするときって、なんだか",
        "ホッとする気持ちになっちゃうわぁ……」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "おまるの中に、濃い色のおしっこが溜まっていく。",
        "ちょっとだけ、アンモニアの匂いがした。",
        "その後ろで、真琴は悲しそうに首を振っていた。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO005D_005",
        "file": "voice/mako_005_mako005D_005.ogg"
      },
      "lines": [
        "「ママっ、こんなの本当のママじゃないって、私は",
        "わかってるからっ……ううっ……」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      },
      "se": [
        {
          "code": "8411A",
          "file": "se/8411a.ogg"
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "やがて、おしっこの勢いがだんだんなくなっていく。",
        "ちょろちょろと漏れるおしっこは、左右によじれて、",
        "割れ目を縁どるヘアーを濡らしていく。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_021",
        "file": "voice/saki_005_mako005D_021.ogg"
      },
      "lines": [
        "「あっあっ、も、もうすぐ終わっちゃうわ。んんっ、",
        "出し切っちゃいそう……んっ、んんっ……」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "早紀さんは名残惜しそうに言いながら、きゅっと",
        "下腹にチカラを入れた。",
        "最後の最後まで、出し切ってしまおうというのだ。",
        "これも、職場でついた癖なのかもしれない。",
        "ぴゅっぴゅっと、残っていたおしっこが飛んだ。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿出し",
        "file": "EV051_04"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_022",
        "file": "voice/saki_005_mako005D_022.ogg"
      },
      "lines": [
        "「はぁっ……ん……あと、ちょっと……んんっ……」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿たれ",
        "file": "EV051_05"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "排尿が終わってから、滴を切るように、クイクイと",
        "股間を振る。",
        "小振りのお尻が、おまるの上で左右に揺れて、",
        "ヘアーや割れ目から滴が飛び散った。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿たれ",
        "file": "EV051_05"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_023",
        "file": "voice/saki_005_mako005D_023.ogg"
      },
      "lines": [
        "「私、尿の切れがあまり良くないの。残尿感があると",
        "仕事中も、モヤモヤしちゃうのが嫌で……」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿たれ",
        "file": "EV051_05"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "まだ気になるのか、おまるを強く握ってチカラを",
        "入れながら、今度は前後に股間を揺らす。",
        "めちゃくちゃエロい仕草だ。",
        "ピチャッ、ピチャッとおまるに水滴が落ちておく。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿たれ",
        "file": "EV051_05"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_024",
        "file": "voice/saki_005_mako005D_024.ogg"
      },
      "lines": [
        "「んっく、んふっ……はぁ～、よく出したわぁ！」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿たれ",
        "file": "EV051_05"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そして、ようやく長い排尿が終わった。",
        "おまるの中にはたっぷりとおしっこが溜まっていて、",
        "ちょっとだけ湯気まで立ちのぼっていた。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿たれ",
        "file": "EV051_05"
      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO005D_006",
        "file": "voice/mako_005_mako005D_006.ogg"
      },
      "lines": [
        "「そ、それじゃあ拭きます」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿たれ",
        "file": "EV051_05"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "トイレットペーパーを構えた真琴が前に出る。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・安堵・尿たれ",
        "file": "EV051_05"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_025",
        "file": "voice/saki_005_mako005D_025.ogg"
      },
      "lines": [
        "「まだよ。まだ終わってないわ。これからウンコを",
        "するから、拭くのはその後でね」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・真面目顔・尿たれ",
        "file": "EV051_06"
      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO005D_007",
        "file": "voice/mako_005_mako005D_007.ogg"
      },
      "lines": [
        "「ううっ、やっぱり……そっちもなの……」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・真面目顔・尿たれ",
        "file": "EV051_06"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "真琴はガックリと項垂れた。",
        "排便をウンコと呼びかえさせたときに、予想していた",
        "のだろう。",
        "そのまま、早紀さんは排便に向かって、おまるの上で",
        "ふんばった。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・真面目顔・尿たれ",
        "file": "EV051_06"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_026",
        "file": "voice/saki_005_mako005D_026.ogg"
      },
      "lines": [
        "「ちょっと待っていてね。ウンコは気張らないと",
        "出ないものだから……んっ、んん～っ！」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・真面目顔・尿たれ",
        "file": "EV051_06"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "さっきと同じように、むっちりした内腿にグッと",
        "チカラが入る。",
        "おしっこで濡れた割れ目が、小さくヒクつく。",
        "誘っているみたいで、なんだかいやらしい。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・真面目顔・尿たれ",
        "file": "EV051_06"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_027",
        "file": "voice/saki_005_mako005D_027.ogg"
      },
      "lines": [
        "「んーっ、んぐっ、んんっ！　普段から、ちょっと",
        "便秘気味なのよね……」"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "言葉どおり、なかなか出てこない。",
        "めちゃくちゃふんばっているみたいで、肩にまで",
        "チカラが入っている。",
        "早紀さんの表情は、ますます険しくなっていく。"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_028",
        "file": "voice/saki_005_mako005D_028.ogg"
      },
      "lines": [
        "「食物繊維も、んんっ、ちゃんと取っているのに、",
        "うーっ、ううっ！　三日も、出てないのっ！」"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "眉を寄せて、歯を食いしばり、怒っているみたいだ。",
        "おしっこのたまった、おまるの上でだけれども。",
        "時間がたったせいか、おしっこのアンモニア臭が",
        "ちょっと強くなってきた。"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_029",
        "file": "voice/saki_005_mako005D_029.ogg"
      },
      "lines": [
        "「んはぁっ！　うう……ダメだわっ！　落ち着いて、",
        "いったん深呼吸してっ……すうっ、はぁぁぁ……」"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "一度ふんばるのをやめて、大股を開いたまま、",
        "その場で静かに深呼吸を始める。",
        "深呼吸に合わせて、柔らかそうな下腹部がへこむ。",
        "早紀さんは大真面目だ。",
        "週に何度か、こんなふうに頑張っているのだろうか。"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_030",
        "file": "voice/saki_005_mako005D_030.ogg"
      },
      "lines": [
        "「もうちょっと……足を開いたほうが……んんっ、",
        "すぅ～っ、はぁぁっ……ううっ……」"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "更に膝をグッと開く早紀さん。",
        "余計に、お尻の穴が見える格好になる。",
        "ぷくっと突きだした、くすんだ色のお尻の穴。",
        "ソコが、閉じたり開いたりするのが伺えた。",
        "すると、突然早紀さんが大声を上げた。"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_031",
        "file": "voice/saki_005_mako005D_031.ogg"
      },
      "lines": [
        "「あっ、あぁっ……きたっ！　深呼吸が効いたわっ！",
        "んっんっ……お腹、ぎゅるぎゅる、いってるっ！」"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そのまま、勢いを逃すまいとして踏ん張る。",
        "平たいお腹が、へっこんだり、膨らんだりした。"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_032",
        "file": "voice/saki_005_mako005D_032.ogg"
      },
      "lines": [
        "「うぐっ、んぐぐっ！　あっあっ、もうすぐよっ、",
        "もうウンコ出そうっ、お腹で動いてるっ！」"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "実の母親の、排便の実況中継。",
        "それを聞く真琴は、愕然としていた。",
        "トイレットペーパーを握った手が小さく震えている。"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_033",
        "file": "voice/saki_005_mako005D_033.ogg"
      },
      "lines": [
        "「あーっ、きてるっ！　もう出口まできてるから、",
        "しっかり見てっ、私のウンコ見てっ！」"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "濡れた割れ目が内側から押されているように、",
        "パクッと開いた。",
        "早紀さんは腰を落としながら、ものすごい形相で",
        "さらにチカラをいれた。"
      ],
      "bg": {
        "label": "#EV051・苦悶・眉寄せ・尿たれ",
        "file": "EV051_07"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_034",
        "file": "voice/saki_005_mako005D_034.ogg"
      },
      "lines": [
        "「ふっぐぅ～っ！　うぅんっ、んんんっ！　んぅっ！",
        "出たぁっ、う～っ、ほらっ、ウンコ出たぁっ！」"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "開かれた脚の間から、カタそうな先っぽが覗いた。",
        "早紀さんの唸り声とともに、黒っぽいソレは",
        "ムリムリと押しだされていく。"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      },
      "se": [
        {
          "code": "8431A",
          "file": "se/8431a.ogg"
        }
      ]
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_035",
        "file": "voice/saki_005_mako005D_035.ogg"
      },
      "lines": [
        "「んぉっ、ふぉぉっ……おっおっ、良かったぁ！",
        "やっと出たぁ……んんっ、はあぁ～っ！」"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      },
      "se": [
        {
          "code": "8431B",
          "file": "se/8431b.ogg"
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "水分の少なそうな、ごつごつした部分が、いきみと",
        "共に出ていくと、あとはスムーズだった。",
        "ちょうどよい太さのものが、ズズッと出ていく。"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_036",
        "file": "voice/saki_005_mako005D_036.ogg"
      },
      "lines": [
        "「ああ～っ、すっごいブリブリってウンコ出てるぅ！",
        "おっ、おおうっ、ひり出されていくぅ！」"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "白くスベスベのお尻の間から出ていく、茶色い汚物。",
        "美人な早紀さんが、尻穴から汚物をひり出す。",
        "その様子に、猛烈に興奮してしまう。",
        "早紀さんの死んだ旦那さんも、こんなところは",
        "見たことがないだろう。"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_037",
        "file": "voice/saki_005_mako005D_037.ogg"
      },
      "lines": [
        "「はふうっ、はぁぁっ……あぁーっ、あっあっ！",
        "おっ、まだ、出るぅっ……はあぁぁっ……！」"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "早紀さんは、気持ちよさそうに肩を落とした。",
        "つやつやして、健康的なソレが滑るように出ていく。"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_038",
        "file": "voice/saki_005_mako005D_038.ogg"
      },
      "lines": [
        "「こんな勢いで出るの、久しぶり、気持ちいい～っ！",
        "こっ、こんな快便、初めてだわっ！」"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "溜まっていたせいか、僕のソレと大して変わらない",
        "ような、太くシッカリしたカタチだ。",
        "女の人のでも、こんなに太いものなんだなぁ。",
        "お尻の穴は完全に開いて、少し突き出てさえいる。"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_039",
        "file": "voice/saki_005_mako005D_039.ogg"
      },
      "lines": [
        "「毎日っ、んんっ、こうだったら、いいんだけどっ！",
        "はぁぁっ、ウンコ出すの、気持ちいいっ！」"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "ポチャンっと音がして、先っぽがおまるに落ちる。",
        "それでも、早紀さんの排便は止まらない。",
        "おまるの持ち手を強く握りながら、更に下腹部に",
        "チカラを込める。"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_040",
        "file": "voice/saki_005_mako005D_040.ogg"
      },
      "lines": [
        "「まだ出るっ！　どんどんウンコ出てくるぅ～っ！",
        "いいわぁ、溜まってるの全部出しちゃうっ！」"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "りきんだせいか、ぶびっと音をたてて、ソレが",
        "飛びだした。",
        "勢いよく落ちたおまるから、おしっこが跳ねあがる。",
        "特有の匂いが、上品なリビングに漂いだした。"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_041",
        "file": "voice/saki_005_mako005D_041.ogg"
      },
      "lines": [
        "「ちょっと匂っちゃってるわね。ごめんなさいね、",
        "フン詰まりだったものだからっ」"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "ちょっと恥ずかしそうに笑う早紀さん。",
        "あまりの下品な物言いに、真琴は絶句している。"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_042",
        "file": "voice/saki_005_mako005D_042.ogg"
      },
      "lines": [
        "「今日はウンコがブリブリ出せて、最高の日だわっ！",
        "あっ、手帖に記録しておかないと……んんっ！」"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "おまるの中に、ソレが溜まっていく。",
        "三日分……九食分が出ているせいで、ところどころで",
        "色やカタさが変わっている。",
        "こんなにたくさんのブツが、早紀さんの腹に溜まって",
        "いただなんて。",
        "あのペタンコのお腹を思いだして、不思議になる。",
        "さすがに、だんだん勢いが収まってきた。",
        "だが、早紀さんはますます顔を険しくした。"
      ],
      "bg": {
        "label": "#EV051・驚き・安堵・排便",
        "file": "EV051_08"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_043",
        "file": "voice/saki_005_mako005D_043.ogg"
      },
      "lines": [
        "「最後まで出し切らない、とっ！　ふぅっ、ふんっ！",
        "んっふ、んぉっ……おっ、おっ……」"
      ],
      "bg": {
        "label": "#EV051・驚き・りきみ・排便",
        "file": "EV051_09"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "何度も尻穴に力を入れて、ぶりっ、ぶりっと、残りを",
        "押しだしていく。",
        "最初よりもずいぶん細く、柔らかそうなブツが、",
        "ボトボトと落ちていく。"
      ],
      "bg": {
        "label": "#EV051・驚き・りきみ・排便",
        "file": "EV051_09"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_044",
        "file": "voice/saki_005_mako005D_044.ogg"
      },
      "lines": [
        "「おうっ、まだウンコ、残ってる、わねっ……んっ！",
        "んんっ！　あとちょっとぉっ……ん～っ！」"
      ],
      "bg": {
        "label": "#EV051・驚き・りきみ・排便",
        "file": "EV051_09"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "間を空けながら、小さなカタマリがひり出される。",
        "本当に残っていたって感じの、小さなブツだ。"
      ],
      "bg": {
        "label": "#EV051・驚き・りきみ・排便",
        "file": "EV051_09"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_045",
        "file": "voice/saki_005_mako005D_045.ogg"
      },
      "lines": [
        "「んぉっ……おっ、おっ……んぐっ、んんんっ！",
        "んっふ、んっ！　んぁ、おっ！」"
      ],
      "bg": {
        "label": "#EV051・驚き・蕩け・排便",
        "file": "EV051_10"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "黒っぽく、カタそうなものが断続的の飛びだす。",
        "カタマリが落ちるたびに、おまるの中のおしっこが",
        "音をたてて跳ねあがる。",
        "ボチャッ！　ボチャッ！",
        "僕でもちょっと引くぐらい、下品な音だった。"
      ],
      "bg": {
        "label": "#EV051・驚き・蕩け・排便",
        "file": "EV051_10"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_046",
        "file": "voice/saki_005_mako005D_046.ogg"
      },
      "lines": [
        "「終わったぁ……はぁぁっ、すごかったわぁ。",
        "久しぶりにしっかりウンコした感じよぉ」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・蕩け・尿たれ",
        "file": "EV051_11"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "彼女は、蕩けた顔で吐息を漏らした。",
        "そして、呆然としている真琴に指示をする。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・蕩け・尿たれ",
        "file": "EV051_11"
      }
    },
    {
      "kind": "line",
      "who": "望月　早紀",
      "voice": {
        "id": "SAKI_005_MAKO005D_047",
        "file": "voice/saki_005_mako005D_047.ogg"
      },
      "lines": [
        "「そうしたら真琴、お尻の穴を綺麗に拭いて。",
        "ウンコが残らないように、しっかりね」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・蕩け・尿たれ",
        "file": "EV051_11"
      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO005D_008",
        "file": "voice/mako_005_mako005D_008.ogg"
      },
      "lines": [
        "「ううっ……はい、分かりました……」"
      ],
      "bg": {
        "label": "#EV051・泣きそう・蕩け・尿たれ",
        "file": "EV051_11"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "まさか自分の母親の尻穴を拭かされるとは、",
        "思ってもいなかっただろう。",
        "僕は満足して、笑みを浮かべながら、その様子を",
        "見続けるのだった……。"
      ],
      "bg": {
        "label": "#EV051・泣きそう・蕩け・尿たれ",
        "file": "EV051_11"
      }
    }
  ],
  "bgm": {
    "track": "M05",
    "file": "bgm/M05.ogg"
  }
}
