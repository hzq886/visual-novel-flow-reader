      },
      "bgv": {
        "id": "BGV_TUBA_F002A",
        "file": "voice/BGV_tuba_f002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA013E_043",
        "file": "voice/tuba_006_tuba013E_043.ogg"
      },
      "lines": [
