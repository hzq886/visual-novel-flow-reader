      "bgv": {
        "id": "BGV_TUBA_F002A",
        "file": "voice/BGV_tuba_f002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "やっぱり、ココへの刺激は快感が別格のようだ。",
        "頭をぶんぶんと振って、激しい喘ぎ声で身悶える。"
      ],
      "bg": {
        "label": "#EV056・アヘ顔舌出し・うっとり舌出し・股間愛撫・股間さわり・愛液",
        "file": "EV056_09"
      },
      "bgv": {
        "id": "BGV_TUBA_F002A",
        "file": "voice/BGV_tuba_f002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA013E_039",
        "file": "voice/tuba_006_tuba013E_039.ogg"
      },
      "lines": [
        "「キスもしてっ！　舌を絡めて、イキたいのっ！",
        "んぢゅ……れる、れるれろっ、んふぅぅ！」"
      ],
      "bg": {
        "label": "#EV056・アヘ顔舌出し・うっとり舌出し・股間愛撫・股間さわり・愛液",
