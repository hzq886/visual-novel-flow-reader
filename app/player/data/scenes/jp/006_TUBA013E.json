      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA013E_044",
        "file": "voice/tuba_006_tuba013E_044.ogg"
      },
      "lines": [
        "「んちゅ……んふっ、ふあぁ……ちゅ、ちゅぶ……」"
      ],
      "bg": {
        "label": "#EV056・アヘ顔舌出し・うっとり舌出し・股間愛撫・股間さわり・潮吹き後",
