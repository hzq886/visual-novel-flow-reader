      },
      "bgv": {
        "id": "BGV_TUBA_F002A",
        "file": "voice/BGV_tuba_f002a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "摘まんでシゴくと、彼女は腰を跳ねさせた。"
      ],
      "bg": {
        "label": "#EV056・眉寄せ感じ舌出し・うっとり舌出し・股間愛撫・股間さわり・愛液",
        "file": "EV056_08"
      },
      "bgv": {
        "id": "BGV_TUBA_F002A",
        "file": "voice/BGV_tuba_f002a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA013E_038",
        "file": "voice/tuba_006_tuba013E_038.ogg"
      },
      "lines": [
        "「んひぃっ！　そ、そうっ、シコシコって、ああっ！",
        "シコシコしてっ！　クリトリスっ、シゴいてぇ！」"
      ],
      "bg": {
        "label": "#EV056・アヘ顔舌出し・うっとり舌出し・股間愛撫・股間さわり・愛液",
