        "offset": [
          234,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "lines": [
        "「ありがとうございます。えっと、帰っている途中で、",
        "ちょっと翼と話をしてまして……」"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（昼）",
        "file": "BG08_01_00"
