      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_009_MAKO010B_003",
        "file": "voice/tuba_009_mako010B_003.ogg"
      },
      "lines": [
        "「さーて、マゾブタに調教をしてあげなくちゃねっ！",
        "あははっ、ブタのケツ穴が丸見えだよぉ～？」"
      ]
    },
    {
      "kind": "narration",
      "pages": [
