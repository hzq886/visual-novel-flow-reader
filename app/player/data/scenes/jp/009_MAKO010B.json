    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_009_MAKO010B_002",
        "file": "voice/tuba_009_mako010B_002.ogg"
      },
      "lines": [
        "「鼻を鳴らして、匂い嗅ぎまくっちゃって……まるで",
        "ブタみたいだね！　このマゾのブタっ！」"
