    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_002_AYAN001B_021",
        "file": "voice/ayan_002_ayan001B_021.ogg"
      },
      "lines": [
        "「そのとき独身の私が残っていたとしたら、この家を",
