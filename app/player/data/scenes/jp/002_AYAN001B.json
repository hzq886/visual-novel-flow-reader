        "face": "CH01B_02_02_104_01",
        "offset": [
          431,
          78
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_002_AYAN001B_019",
        "file": "voice/ayan_002_ayan001B_019.ogg"
      },
      "lines": [
        "「そうして将来、結婚するようになったとき、もしも",
        "姉が独身だったら、遠慮しちゃうでしょう？」"
      ],
      "bg": {
        "label": "#背景・喫茶店（夕）",
        "file": "BG20_02_00"
      },
      "sprite": {
        "label": "綾菜（中）・通常２（夕）・私服０２・驚き１",
