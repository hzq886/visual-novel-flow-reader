    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_002_AYAN001B_022",
        "file": "voice/ayan_002_ayan001B_022.ogg"
      },
      "lines": [
        "「だから、そうなる前に、私がお嫁に行ってしまえば",
        "いいのかなって。そうすれば気兼ねなく……」"
      ],
      "bg": {
        "label": "#背景・喫茶店（夕）",
        "file": "BG20_02_00"
      },
      "sprite": {
        "label": "綾菜（中）・通常２（夕）・私服０２・驚き１",
        "body": "CH01B_02_02_003_02",
        "face": "CH01B_02_02_104_01",
        "offset": [
          431,
          78
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "lines": [
        "「だ、だめだよ！　そんな理由で結婚なんてっ」"
      ],
      "bg": {
        "label": "#背景・喫茶店（夕）",
        "file": "BG20_02_00"
      },
      "sprite": {
        "label": "綾菜（中）・通常２（夕）・私服０２・驚き１",
        "body": "CH01B_02_02_003_02",
        "face": "CH01B_02_02_104_01",
        "offset": [
          431,
          78
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "なんと言ったらいいのか、分からない。",
        "様々な感情が溢れて、僕は混乱してしまっていた。",
        "アイツは、もう『近づかないように』してある。",
        "あとは、綾姉が忘れてしまえば……。",
        "僕は、さっき決めたばかりのキーワードを言った。"
      ],
      "bg": {
        "label": "#背景・喫茶店（夕）",
        "file": "BG20_02_00"
      },
      "sprite": {
        "label": "綾菜（中）・通常１（夕）・私服０２・驚き１",
        "body": "CH01B_01_02_003_02",
        "face": "CH01B_01_02_104_01",
        "offset": [
          426,
          73
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "lines": [
