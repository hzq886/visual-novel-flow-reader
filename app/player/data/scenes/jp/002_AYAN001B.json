    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_002_AYAN001B_020",
        "file": "voice/ayan_002_ayan001B_020.ogg"
      },
      "lines": [
        "「結婚はともかく、いずれは、あなたも卒業して、",
