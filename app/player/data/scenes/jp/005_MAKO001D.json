        ]
      },
      "se": [
        {
          "code": "9001A",
          "file": "se/9001a.ogg"
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "パンッ！",
        "何度か瞬きしてから、真琴は言う。"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
