          "code": "0035A",
          "file": "se/0035a.ogg"
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "なんだか、役割のひとつに思えるから……。",
        "………。",
        "……。",
        "…。"
      ],
