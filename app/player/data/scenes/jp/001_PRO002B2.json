      "voice": {
        "id": "AYAN_001_PRO003A_008",
        "file": "voice/ayan_001_pro003A_008.ogg"
      },
      "lines": [
        "「はい、お弁当。残さず食べてくれると嬉しいわ」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprites": [
        {
          "label": "綾菜（中）・通常１（昼）・私服０３・通常１",
          "body": "CH01B_01_01_003_03",
          "face": "CH01B_01_01_101_01",
          "offset": [
            426,
            73
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「ありがとう。明日は、自分で作るから」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprites": [
        {
          "label": "綾菜（中）・通常１（昼）・私服０３・通常１",
          "body": "CH01B_01_01_003_03",
          "face": "CH01B_01_01_101_01",
          "offset": [
            426,
            73
          ]
        }
      ]
    },
    {
      "kind": "narration",
      "lines": [
        "そろそろ綾姉も、喫茶店へ行って、開店の準備を",
        "しなくてはいけない。",
        "そういうこともあって、うちの朝食の時間は、",
        "ちょっと早めだ。"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprites": [
        {
          "label": "綾菜（中）・通常１（昼）・私服０３・通常１",
          "body": "CH01B_01_01_003_03",
          "face": "CH01B_01_01_101_01",
          "offset": [
            426,
            73
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「戸締りはしておくから。先に出ても大丈夫だよ。",
        "いってらっしゃい」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprites": [
        {
          "label": "綾菜（中）・通常１（昼）・私服０３・通常１",
          "body": "CH01B_01_01_003_03",
          "face": "CH01B_01_01_101_01",
          "offset": [
            426,
            73
          ]
        }
      ]
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO003A_023",
        "file": "voice/ayan_001_pro003A_023.ogg"
      },
      "lines": [
        "「いつもありがとう。助かるわ」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprites": [
        {
          "label": "綾菜（中）・通常１（昼）・私服０３・にっこり１",
