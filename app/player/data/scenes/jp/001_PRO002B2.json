      ]
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO003B_008",
        "file": "voice/suzu_001_pro003B_008.ogg"
      },
      "lines": [
        "「それじゃあ、いってきます」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprites": [
        {
          "label": "涼菜（中）・通常１（昼）・スーツ０１・通常１",
