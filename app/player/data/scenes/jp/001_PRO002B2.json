    },
    {
      "kind": "narration",
      "lines": [
        "洗っていると、綾姉が弁当箱を横に置いてくれる。"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprites": [
        {
          "label": "綾菜（中）・通常１（昼）・私服０３・通常１",
          "body": "CH01B_01_01_003_03",
          "face": "CH01B_01_01_101_01",
          "offset": [
            426,
            73
