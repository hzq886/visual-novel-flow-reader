      "voice": {
        "id": "TUBA_001_PRO002B3_001",
        "file": "voice/tuba_001_pro002B3_001.ogg"
      },
      "lines": [
        "「おはようっ！　寝グセついてないかな？」"
      ],
      "bg": {
        "label": "#背景・楠木家外観（昼）",
        "file": "BG07_01_00"
