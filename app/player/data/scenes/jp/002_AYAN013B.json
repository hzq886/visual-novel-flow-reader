        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「分かったよ、綾姉！」"
      ],
      "bg": {
        "label": "#EV082・うっとり蕩け2・あり・奥まで挿入・愛液",
