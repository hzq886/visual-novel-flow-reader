    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_007_KAED001A_034",
        "file": "voice/kaed_007_kaed001A_034.ogg"
      },
      "lines": [
        "「ぜんぶ脱いで、ベッドに仰向けになってくれる？",
        "私が上になるから……」"
      ],
      "bg": {
        "label": "#背景・楠木夫婦の寝室（昼）",
