        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_007_KAED001A_003",
        "file": "voice/kaed_007_kaed001A_003.ogg"
      },
      "lines": [
        "「ふうっ！？　はっ、はぁぁぁっ……んんっ……」"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（昼）",
        "file": "BG08_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・私服０１・呆れ１",
        "body": "CH05B_01_01_003_01",
        "face": "CH05B_01_01_107_01",
        "offset": [
          234,
          70
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "すぐに楓さんの心は、深いところへ落ちる。",
        "その状態になってから、僕はいったん翼のところへ",
        "行くことにした。",
        "もしも途中で、降りてきたら大変だからだ。",
        "部屋に戻ると、翼が僕を見る。",
        "もう部屋着に着替えていたようだ。"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（昼）",
        "file": "BG08_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH05B_03_01_003_01",
        "face": "CH05B_03_01_103_01",
        "offset": [
          232,
          64
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「あれっ？　なにか忘れ物でもしたの？」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・私服０１・困り１",
        "body": "CH03B_02_01_003_01",
        "face": "CH03B_02_01_107_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "帰ったはずなのに、戻ってきたから、そういう風に",
        "尋ねるのは当然だ。",
        "すぐに僕は、キーワードを言った。"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・私服０１・困り１",
        "body": "CH03B_02_01_003_01",
        "face": "CH03B_02_01_107_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「『空飛ぶ元気っ子』」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・私服０１・困り１",
        "body": "CH03B_02_01_003_01",
        "face": "CH03B_02_01_107_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「はうっ！？　あっ、あっ、はぁぁぁっ……」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・私服０１・困り１",
        "body": "CH03B_02_01_003_01",
        "face": "CH03B_02_01_107_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そして、催眠状態になった彼女に言う。"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「いいですか。あなたは夕食の時間に呼ばれるまで、",
        "ベッドで横になって休みますよ」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「ゆうしょく……よばれるまで、ベッドで……」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "とりあえず、これで大丈夫だろう。"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「ドアが閉じる音がしたら、いつもの心の状態に",
        "戻ります。和樹が戻って来たことは忘れます」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そうして、僕は部屋を出る。",
        "そして、音をたてて扉を閉じた。",
        "さあ、楓さんのところへ行こう。",
        "楓さんは、さっきと同じ状態で立っていた。",
        "翼のほうは、夕食で呼ばれるまでは、寝ている。",
        "裕司さんも、まだ帰っては来ないだろう。",
        "僕は唾を飲んで、ゴクリと喉を鳴らす。",
        "そして彼女に『暗示』をかけていく。"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      },
      "se": [
        {
          "code": "0031C",
          "file": "se/0031c.ogg"
        }
      ]
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "lines": [
        "「……古橋和樹にされた質問は、なんでも答えます。",
        "どんな内容でも、おかしいとは思いませんよ」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_007_KAED001A_004",
        "file": "voice/kaed_007_kaed001A_004.ogg"
      },
      "lines": [
        "「はい……しつもん……なんでも、こたえます。",
        "おかしいとは、おもいません……」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "楓さんに、色々と教えてもらおう。",
        "彼女に関する、プライベートなことも。"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "lines": [
        "「彼と二人きりの時は、エッチなことを話すように",
        "しましょう。そうすると楽しくなりますよ」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_007_KAED001A_005",
        "file": "voice/kaed_007_kaed001A_005.ogg"
      },
      "lines": [
        "「えっちなこと、はなすように……そうすると、",
        "たのしくなります……」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "いちおう、僕と二人きりの時と限定しておく。",
        "周囲の人にエッチな話をしまくるようになったら、",
        "さすがに問題があるからだ。",
        "そして、翼と同じように『ゲーム』をしてもらおう。"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "lines": [
        "「あなたは、これから和樹君をゲームに誘います。",
        "やるときは夫婦の寝室に連れて行きましょう」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_007_KAED001A_006",
        "file": "voice/kaed_007_kaed001A_006.ogg"
      },
      "lines": [
        "「げーむに、さそいます……ふうふの、しんしつに」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "せっかくだし、場所を変えることにした。",
        "この家には何度も来ているけれど、夫婦の寝室は",
        "見たことがなかった。",
        "裕司さんとの二人だけの場所なのだし、普通なら",
        "入る機会などあるはずもない。",
        "そして僕は、ちょっと考えてから言った。"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "lines": [
        "「彼とやるのは……自分がどれだけエッチか、相手に",
        "アピールするゲームです」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_007_KAED001A_007",
        "file": "voice/kaed_007_kaed001A_007.ogg"
      },
      "lines": [
        "「どれだけえっちか……あぴーるする……」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "我ながら酷い内容だと思う。",
        "でもここは、自分の欲望に素直にならせてもらおう。",
        "どちらにせよ、すでにやったコトの取り返しは",
        "つかないのだから。"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "lines": [
        "「そうです。相手よりも、エッチなことが好きだと",
        "示したほうが勝ちという勝負ですよ」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_007_KAED001A_008",
        "file": "voice/kaed_007_kaed001A_008.ogg"
      },
      "lines": [
        "「あいてよりも……えっちなことが、すき……」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そのまま調子に乗って、言葉を続ける。"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
        "body": "CH03B_03_01_003_01",
        "face": "CH03B_03_01_104_01",
        "offset": [
          319,
          102
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "lines": [
        "「これはゲームだから、何も恥ずかしくないです。",
        "とにかくスケベな女になりましょう」"
      ],
      "bg": {
        "label": "#背景・翼の部屋（昼）",
        "file": "BG09_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常３（昼）・私服０１・催眠１",
