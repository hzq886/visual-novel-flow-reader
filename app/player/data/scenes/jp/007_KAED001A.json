        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_007_KAED001A_033",
        "file": "voice/kaed_007_kaed001A_033.ogg"
      },
      "lines": [
        "「うふふっ、いいわよ！　やりましょう！」"
      ],
      "bg": {
        "label": "#背景・楠木夫婦の寝室（昼）",
        "file": "BG10_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・エロ下着０１・にっこり１",
