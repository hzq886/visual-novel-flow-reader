    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_007_KAED001A_011",
        "file": "voice/kaed_007_kaed001A_011.ogg"
      },
      "lines": [
        "「ここじゃなんだし、寝室のほうへ行きましょうか。",
