      "voice": {
        "id": "MAKO_005_MAKO001C_001",
        "file": "voice/mako_005_mako001C_001.ogg"
      },
      "lines": [
        "「な、なにこれ！？　身体が勝手にっ……！？」"
      ],
      "bg": {
        "label": "#背景・教室（夕）",
        "file": "BG16_02_00"
      },
      "sprites": [
        {
          "label": "真琴（中）・通常１（夕）・制服０１・驚き１",
