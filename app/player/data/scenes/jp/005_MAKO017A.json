          150
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "適当な理由をつけて、二人きりになるためだ。"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
        "file": "BG16_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・制服０１・通常１",
