    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「ごめん！　ちょっと放課後に、ノートを写させて",
        "もらってもいいかな？」"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
        "file": "BG16_01_00"
