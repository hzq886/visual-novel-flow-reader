      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO015B_045",
        "file": "voice/mako_005_mako015B_045.ogg"
      },
      "lines": [
        "「はぁぁんっ……チ×ポすきぃ……だいしゅきぃ」"
      ],
      "bg": {
        "label": "#EV084・眉寄せ蕩け・未挿入・精液たれ",
        "file": "EV084_07"
      },
      "bgv": {
        "id": "BGV_MAKO_H003A",
        "file": "voice/BGV_mako_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "私に最高の快感を与えてくれて、妊娠までさせて",
        "くれるチ×ポ。",
        "どうして私は、もっと早く屈服しなかったのか。",
        "こんなにも、気持ち良いことをしてもらえるのに。",
        "こんなにも、幸せになれるのに……。",
