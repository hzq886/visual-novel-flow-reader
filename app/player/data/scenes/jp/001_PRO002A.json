      "voice": {
        "id": "MAKO_001_PRO002A_002",
        "file": "voice/mako_001_pro002A_002.ogg"
      },
      "lines": [
        "「私も、生徒会の仕事は無いから、久しぶりに三人で",
        "綾菜さんのところへ行きましょうか」"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
