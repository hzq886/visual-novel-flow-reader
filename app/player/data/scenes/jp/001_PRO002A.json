      "voice": {
        "id": "MAKO_001_PRO002A_001",
        "file": "voice/mako_001_pro002A_001.ogg"
      },
      "lines": [
        "「まだ結果が出ていないんだから、安心するのは",
        "早いと思うわよ？」"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
        "file": "BG16_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・制服０１・通常１",
