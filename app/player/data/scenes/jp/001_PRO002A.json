      "voice": {
        "id": "TUBA_001_PRO002A_001",
        "file": "voice/tuba_001_pro002A_001.ogg"
      },
      "lines": [
        "「やっとテスト期間が終わったねっ！　ようやく",
        "これで羽をのばせるよー！」"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
        "file": "BG16_01_00"
