        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そこに、真琴もやって来た。",
        "僕たちは現在、同じクラスだった。"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
        "file": "BG16_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・制服０１・通常１",
