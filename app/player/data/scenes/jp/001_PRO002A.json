    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_001_PRO002A_003",
        "file": "voice/mako_001_pro002A_003.ogg"
      },
      "lines": [
        "「翼が赤点を取ったら、また勉強会をしないとね。",
        "前の追試のときみたいに」"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
        "file": "BG16_01_00"
