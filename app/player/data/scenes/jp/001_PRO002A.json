  "beats": [
    {
      "kind": "narration",
      "lines": [
        "……授業が終わって、席を立つ。",
        "すると翼が、僕のほうに近寄ってきた。"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
        "file": "BG16_01_00"
      },
      "se": [
        {
          "code": "0001C",
