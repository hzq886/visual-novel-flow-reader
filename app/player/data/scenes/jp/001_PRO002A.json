    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_001_PRO002A_002",
        "file": "voice/tuba_001_pro002A_002.ogg"
      },
      "lines": [
        "「大丈夫、赤点は取らないよ！　カズと真琴ちゃんに",
        "教えてもらったところ、バッチリだったし！」"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
        "file": "BG16_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常１（昼）・制服０１・にっこり１",
        "body": "CH03B_01_01_004_01",
        "face": "CH03B_01_01_102_01",
        "offset": [
          331,
          70
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「確かに、ヤマを張ったところは、当たってたね」"
      ],
      "bg": {
        "label": "#背景・教室（昼）",
        "file": "BG16_01_00"
