    },
    {
      "kind": "narration",
      "lines": [
        "これくらいでいいだろうか？"
      ],
      "bg": {
        "label": "#背景・古橋家脱衣所（昼）",
        "file": "BG26_01_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常３（昼）・裸０１・催眠１",
        "body": "CH02B_03_01_001_01",
        "face": "CH02B_03_01_104_01",
        "offset": [
          221,
