        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "voice": {
        "id": "SUZU_003_SUZU003B_006",
        "file": "voice/suzu_003_suzu003B_006.ogg"
      },
      "lines": [
        "「きもちよくなったら、しょうじきに……いっても、",
        "はずかしくは、ありません……」"
      ],
      "bg": {
        "label": "#背景・古橋家脱衣所（昼）",
        "file": "BG26_01_00"
