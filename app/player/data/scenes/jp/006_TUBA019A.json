        "offset": [
          238,
          135
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "その真琴の言葉は、無視される。",
        "僕にも、そして翼にも。"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・私服０１・呆れ１",
        "body": "CH04B_02_01_003_01",
        "face": "CH04B_02_01_107_01",
        "offset": [
          238,
          135
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA019A_002",
        "file": "voice/tuba_006_tuba019A_002.ogg"
      },
      "lines": [
        "「それじゃあ、デートしよっか！　どこに行く？」"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・私服０２・にっこり１",
        "body": "CH03B_02_01_003_02",
