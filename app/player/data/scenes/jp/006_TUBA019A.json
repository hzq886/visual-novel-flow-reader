        "face": "CH04B_01_01_105_01",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "ちゃんと、理解してくれたようだ。",
        "自分の立場が、どういうものであるかを。"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・私服０１・怒り１",
        "body": "CH04B_01_01_003_01",
        "face": "CH04B_01_01_105_01",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「翼が決めていいよ。どこに行きたい？」"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常１（昼）・私服０１・怒り１",
        "body": "CH04B_01_01_003_01",
        "face": "CH04B_01_01_105_01",
        "offset": [
          235,
          150
        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA019A_003",
        "file": "voice/tuba_006_tuba019A_003.ogg"
      },
      "lines": [
        "「うーん……できれば、先にお昼にしたいかな。",
        "ちょっとお腹すいてるし……そこのお店で！」"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常１（昼）・私服０２・困り１",
