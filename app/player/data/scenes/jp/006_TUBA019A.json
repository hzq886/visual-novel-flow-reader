          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「ううん。僕も、さっき来たところだから」"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "翼（中）・通常２（昼）・私服０２・通常１",
