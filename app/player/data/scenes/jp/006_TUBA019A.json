        "face": "CH03B_02_01_101_01",
        "offset": [
          315,
          83
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「カラオケボックスで、歌いたいの？」"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
