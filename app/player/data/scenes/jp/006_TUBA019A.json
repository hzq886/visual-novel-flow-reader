    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA019A_004",
        "file": "voice/tuba_006_tuba019A_004.ogg"
      },
      "lines": [
        "「ええーっ、こんなフリフリのスカート、ボクに",
