      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・私服０１・悲しみ１",
        "body": "CH04B_02_01_003_01",
        "face": "CH04B_02_01_106_01",
        "offset": [
          238,
          135
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「この服とか、翼に似合うんじゃない？」"
      ],
      "bg": {
        "label": "#背景・街中（昼）",
        "file": "BG21_01_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（昼）・私服０１・悲しみ１",
        "body": "CH04B_02_01_003_01",
        "face": "CH04B_02_01_106_01",
        "offset": [
          238,
          135
        ]
