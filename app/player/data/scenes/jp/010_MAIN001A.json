    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「大丈夫。ちゃんと睡眠はとったよ」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常２（昼）・スーツ０１・通常１",
        "body": "CH02B_02_01_003_01",
        "face": "CH02B_02_01_101_01",
        "offset": [
          238,
          76
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そして僕たちは、朝食をとる。"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（昼）",
        "file": "BG02_01_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常２（昼）・スーツ０１・通常１",
        "body": "CH02B_02_01_003_01",
