      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そして強張っていた姉さんの体が脱力していく。",
