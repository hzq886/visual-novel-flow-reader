      "bg": {
        "label": "#EV067・微笑み・精液",
        "file": "EV067_05"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「もちろん、そのつもりだよ」"
      ],
      "bg": {
        "label": "#EV067・微笑み・精液",
        "file": "EV067_05"
      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      }
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_041",
        "file": "voice/ayan_002_ayan012B_041.ogg"
      },
      "lines": [
        "「うふふっ、愛する人の赤ちゃんだもの、何人だって",
