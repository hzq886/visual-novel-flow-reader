      },
      "bgv": {
        "id": "BGV_AYAN_H003A",
        "file": "voice/BGV_ayan_h003a.ogg"
      },
      "flash": 2
    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_038",
        "file": "voice/ayan_002_ayan012B_038.ogg"
      },
      "lines": [
        "「んっ……はぁぁぁっ！　はぁ、はぁぁ……！」"
