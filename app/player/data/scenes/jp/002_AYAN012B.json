      },
      "bgv": {
        "id": "BGV_AYAN_H001A",
        "file": "voice/BGV_ayan_h001a.ogg"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "ゆっくりとした抽送を、綾姉もしっかりと感じてる。",
