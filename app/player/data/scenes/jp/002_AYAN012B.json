    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_002_AYAN012B_005",
        "file": "voice/ayan_002_ayan012B_005.ogg"
      },
      "lines": [
        "「安定期になったし、オマ×コに入れて欲しいけれど",
