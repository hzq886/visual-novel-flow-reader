      "bg": {
        "label": "#背景・綾菜の部屋（夜）",
        "file": "BG04_03_00"
      },
      "sprite": {
        "label": "綾菜（中）・通常２（昼）・妊娠０１・うっとり１",
        "body": "CH01B_02_01_005_01",
        "face": "CH01B_02_01_103_01",
        "offset": [
          431,
          78
