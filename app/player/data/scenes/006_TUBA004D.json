        ]
      }
    },
    {
      "kind": "line",
      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA004D_008",
        "file": null
      },
      "lines": [
        "「もちろん、ズルなんかしないよ！　ちゃーんと",
        "イッたって言うから！」"
      ],
      "bg": {
        "label": "#EV034・なし・デフォ・愛液",
        "file": "EV034_01"
      },
      "sprite": {
        "label": "翼（中）・通常１（昼）・裸０１・にっこり１",
        "body": "CH03B_01_01_001_01",
