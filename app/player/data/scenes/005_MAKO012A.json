    {
      "kind": "line",
      "who": "望月　真琴",
      "lines": [
        "「申し訳ありませんっ！」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・真琴の部屋（夕）",
        "file": "BG12_92_00"
