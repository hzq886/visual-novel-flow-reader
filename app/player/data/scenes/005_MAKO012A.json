    {
      "kind": "line",
      "who": "望月　真琴",
      "voice": {
        "id": "MAKO_005_MAKO012A_005",
        "file": "voice/mako_005_mako012A_005.ogg"
      },
      "lines": [
        "「ベッドの上に座りなさい。私を抱きながら、",
        "おっぱいにも愛撫をするのよ」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・真琴の部屋（夕）",
