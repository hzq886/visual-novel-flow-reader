      "voice": {
        "id": "MAKO_005_MAKO012A_004",
        "file": "voice/mako_005_mako012A_004.ogg"
      },
      "lines": [
        "「……今日は、普通に、私のことを抱きなさい。",
        "そのチ×ポで奉仕するのよ」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・真琴の部屋（夕）",
        "file": "BG12_92_00"
      },
      "sprite": {
        "label": "真琴（中）・通常２（夕）・私服０１・通常１",
        "body": "CH04B_02_02_003_01",
