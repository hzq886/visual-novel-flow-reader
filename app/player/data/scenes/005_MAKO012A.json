        "offset": [
          238,
          135
        ]
      }
    },
    {
      "kind": "line",
      "who": "望月　真琴",
      "lines": [
        "「はい、分かりました！　ご奉仕させて頂きます！」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・真琴の部屋（夕）",
