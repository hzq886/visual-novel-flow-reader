      "voice": {
        "id": "MAKO_005_MAKO012A_002",
        "file": "voice/mako_005_mako012A_002.ogg"
      },
      "lines": [
        "「脱ぐのが遅いのよっ！　この、ノロマ！　クズ！」"
      ],
      "bg": {
        "label": "#背景・アイキャッチ・真琴の部屋（夕）",
