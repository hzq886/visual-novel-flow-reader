    },
    {
      "kind": "narration",
      "lines": [
        "姉さんが、ため息をつきながら言う。"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常１（昼）・裸０１・悲しみ１",
        "body": "CH02B_01_01_001_01",
        "face": "CH02B_01_01_106_01",
        "offset": [
