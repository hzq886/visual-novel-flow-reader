        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "パン！",
        "涼姉はまた目をパチパチさせて、正気に戻った。",
        "僕を見つけて、パッと顔を輝かせる。"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常３（昼）・スーツ０１・驚愕１",
        "body": "CH02B_03_01_003_01",
        "face": "CH02B_03_01_102_01",
        "offset": [
          221,
          75
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_004_FUTA003D_009",
        "file": null
      },
      "lines": [
        "「あっ、おとーたん！　ねぇねぇ、すずとあそぼ！」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常２（昼）・スーツ０１・にっこり１",
