      "voice": {
        "id": "MOBA_001_PRO001K_008",
        "file": "voice/moba_001_pro001K_008.ogg"
      },
      "lines": [
        "「最初、店のことを教えているときでも、もちろん",
        "お給料は出すと言っていたし……」"
      ],
      "bg": {
        "label": "#背景・喫茶店（幼少・昼）",
