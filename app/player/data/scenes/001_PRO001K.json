      "bg": {
        "label": "#背景・喫茶店（幼少・昼）",
        "file": "BG20_11_00"
      },
      "sprite": {
        "label": "旧綾菜（中）・通常１（昼）・制服０１・困り１",
        "body": "CH21B_01_01_002_01",
        "face": "CH21B_01_01_105_01",
        "offset": [
          341,
          100
        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　涼菜",
      "voice": {
        "id": "SUZU_001_PRO001K_002",
        "file": "voice/suzu_001_pro001K_002.ogg"
      },
      "lines": [
        "「姉さん、受けましょう。後で詳しく確認するけれど",
        "立地条件だけでも、すごくいい話だわ」"
      ],
      "bg": {
        "label": "#背景・喫茶店（幼少・昼）",
        "file": "BG20_11_00"
      },
      "sprite": {
        "label": "旧涼菜（中）・通常１（昼）・制服０１・微笑み１",
        "body": "CH22B_01_01_002_01",
        "face": "CH22B_01_01_107_01",
        "offset": [
          318,
          172
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "どうやら、頭の中で計算していたみたいだ。",
        "涼菜姉さんがいけると思ったのなら、間違いない。",
        "それで、ようやく綾菜姉さんは決心した。"
      ],
      "bg": {
        "label": "#背景・喫茶店（幼少・昼）",
        "file": "BG20_11_00"
      },
      "sprite": {
        "label": "旧涼菜（中）・通常１（昼）・制服０１・微笑み１",
