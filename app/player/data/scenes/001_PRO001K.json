    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "voice": {
        "id": "AYAN_001_PRO001K_003",
        "file": "voice/ayan_001_pro001K_003.ogg"
      },
      "lines": [
        "「そうですね……素敵なお店です」"
      ],
      "bg": {
        "label": "#背景・喫茶店（幼少・昼）",
        "file": "BG20_11_00"
