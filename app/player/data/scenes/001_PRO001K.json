    },
    {
      "kind": "line",
      "who": "親戚の叔父さん",
      "voice": {
        "id": "MOBA_001_PRO001K_006",
        "file": "voice/moba_001_pro001K_006.ogg"
      },
      "lines": [
        "「とりあえず、お店を見に行くのはどうだい？",
        "歩いて行ける距離にあるから」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
      },
      "sprite": {
        "label": "旧綾菜（中）・通常１（昼）・制服０１・驚き１",
        "body": "CH21B_01_01_002_01",
        "face": "CH21B_01_01_103_01",
        "offset": [
          341,
          100
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "叔父さんが、そう提案する。",
        "僕たちはみんなで、そのお店へ行くことになった。",
        "ちょっと歩いたけれど、それほど遠くではなかった。",
        "そして、お店の中に入る。",
        "自由に中を見てもらっていいと、そこのご主人に",
        "言われていたらしい。"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
      },
      "sprite": {
        "label": "旧綾菜（中）・通常１（昼）・制服０１・驚き１",
        "body": "CH21B_01_01_002_01",
        "face": "CH21B_01_01_103_01",
        "offset": [
          341,
          100
        ]
      }
    },
    {
      "kind": "line",
      "who": "親戚の叔父さん",
      "voice": {
        "id": "MOBA_001_PRO001K_007",
        "file": "voice/moba_001_pro001K_007.ogg"
      },
      "lines": [
        "「どうかな？　落ち着いた感じの、なかなか良い",
        "お店だろう？」"
      ],
      "bg": {
        "label": "#背景・喫茶店（幼少・昼）",
