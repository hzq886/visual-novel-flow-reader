    {
      "kind": "line",
      "who": "親戚の叔父さん",
      "voice": {
        "id": "MOBA_001_PRO001K_002",
        "file": "voice/moba_001_pro001K_002.ogg"
      },
      "lines": [
        "「そうか……それなら、ちょっと良さそうな話が",
        "あるのだけどね」"
