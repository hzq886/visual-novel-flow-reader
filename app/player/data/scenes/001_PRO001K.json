        "face": "CH22B_01_01_101_01",
        "offset": [
          318,
          172
        ]
      }
    },
    {
      "kind": "line",
      "who": "親戚の叔父さん",
      "voice": {
        "id": "MOBA_001_PRO001K_003",
        "file": "voice/moba_001_pro001K_003.ogg"
      },
      "lines": [
        "「知り合いの老夫婦が、喫茶店をやっていたのだけど",
        "年齢的に厳しくて、やめるそうでね」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
      },
      "sprite": {
        "label": "旧涼菜（中）・通常１（昼）・制服０１・通常１",
        "body": "CH22B_01_01_002_01",
        "face": "CH22B_01_01_101_01",
        "offset": [
          318,
          172
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "叔父さんは、落ち着いた声で説明していく。"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（幼少・昼）",
        "file": "BG02_11_00"
