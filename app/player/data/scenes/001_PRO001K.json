      "voice": {
        "id": "AYAN_001_PRO001K_005",
        "file": "voice/ayan_001_pro001K_005.ogg"
      },
      "lines": [
        "「分かりました。とりあえず、働かせて頂いて、",
        "私のことを、判断してもらえれば……」"
      ],
      "bg": {
        "label": "#背景・喫茶店（幼少・昼）",
        "file": "BG20_11_00"
      },
      "sprite": {
        "label": "旧涼菜（中）・通常１（昼）・制服０１・微笑み１",
