      "voice": {
        "id": "AYAN_001_PRO001K_004",
        "file": "voice/ayan_001_pro001K_004.ogg"
      },
      "lines": [
        "「あっ、でも私、家のこともしないといけないので。",
        "みんなの夕食を作ったりとか……」"
      ],
      "bg": {
        "label": "#背景・喫茶店（幼少・昼）",
