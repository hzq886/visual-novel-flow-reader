      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_008_TUBA009A_001",
        "file": null
      },
      "lines": [
        "「いやぁ、子供と孫が、同時に出来るなんてなぁ！",
        "これも和樹くんが頑張ってくれたおかげだよ！」"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（昼）",
        "file": "BG08_01_00"
