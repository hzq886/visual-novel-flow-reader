      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO001D_002",
        "file": null
      },
      "lines": [
        "「あっ、いらっしゃい。そのまま入ってー」"
      ],
      "bg": {
        "label": "#背景・楠木家外観（幼少・昼）",
        "file": "BG07_11_00"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そう言われて、家の中へと入る。",
        "そして、まっすくリビングへ向かった。",
        "何度も来ているので、迷うこともない。",
        "そこでは、翼と楓さん、そしてお父さんがいた。",
        "なにやら話し込んでいるようだった。"
      ],
      "bg": {
        "label": "#背景・楠木家外観（幼少・昼）",
        "file": "BG07_11_00"
      }
    },
    {
