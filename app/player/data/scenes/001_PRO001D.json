  "title": "幼少回想\\N家族",
  "beats": [
    {
      "kind": "narration",
      "lines": [
        "……僕は、いつものように翼の家に遊びに行く。",
        "インターホンを押して、応答を待つ。"
      ],
      "bg": {
        "label": "#背景・楠木家外観（幼少・昼）",
        "file": "BG07_11_00"
      }
    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_001_PRO001D_001",
        "file": null
      },
      "lines": [
        "「はーい、どなたですか？」"
      ],
      "bg": {
        "label": "#背景・楠木家外観（幼少・昼）",
        "file": "BG07_11_00"
      }
    },
    {
      "kind": "narration",
      "lines": [
        "すぐに反応があり、楓さんの声がした。"
      ],
      "bg": {
        "label": "#背景・楠木家外観（幼少・昼）",
        "file": "BG07_11_00"
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「こんにちは、かずきです」"
      ],
      "bg": {
        "label": "#背景・楠木家外観（幼少・昼）",
        "file": "BG07_11_00"
      }
