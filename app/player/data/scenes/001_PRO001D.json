      "who": "楠木　裕司",
      "voice": {
        "id": "MOBD_001_PRO001D_001",
        "file": null
      },
      "lines": [
        "「……それで翼は、どうして習っている空手を",
        "やめたいのかな？」"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（幼少・昼）",
        "file": "BG08_11_00"
