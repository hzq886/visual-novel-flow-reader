      "who": "古橋　和樹",
      "voice": {
        "id": "SUZU_004_FUTA002A_001",
        "file": null
      },
      "lines": [
        "「あら、ありがとう。それじゃあ、お願いするわね」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
