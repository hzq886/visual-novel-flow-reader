      "who": "古橋　和樹",
      "voice": {
        "id": "SUZU_004_FUTA002A_002",
        "file": null
      },
      "lines": [
        "「えっと、ブラジャーの外し方は、分かるわよね？",
        "ちょっと汚れてるショーツも、脱がしちゃって」"
      ],
      "bg": {
        "label": "#背景・涼菜の部屋（夜）",
        "file": "BG05_03_00"
      },
      "sprite": {
        "label": "涼菜（中）・通常２（昼）・下着０１・通常１",
