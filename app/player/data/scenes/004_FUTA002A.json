    },
    {
      "kind": "line",
      "who": "古橋　綾菜",
      "lines": [
        "「おかえりなさい。お仕事、お疲れ様」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（夜）",
        "file": "BG02_03_00"
