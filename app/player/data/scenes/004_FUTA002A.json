        ]
      }
    },
    {
      "kind": "line",
      "who": "古橋　和樹",
      "lines": [
        "「おかえりなさい。お疲れ様」"
      ],
      "bg": {
        "label": "#背景・古橋家リビング（夜）",
        "file": "BG02_03_00"
