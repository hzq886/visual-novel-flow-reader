    },
    {
      "kind": "line",
      "who": "楠木　楓",
      "voice": {
        "id": "KAED_006_TUBA004A_002",
        "file": null
      },
      "lines": [
        "「うーん、本当に、子供の頃から変わらないわよね。",
        "ちょっとくらい、進展してもいいのに……」"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（昼）",
