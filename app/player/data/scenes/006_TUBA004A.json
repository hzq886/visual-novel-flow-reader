      "who": "楠木　翼",
      "voice": {
        "id": "TUBA_006_TUBA004A_002",
        "file": null
      },
      "lines": [
        "「ただいまっ！　今日は、二人で部屋で遊ぶから！」"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（昼）",
        "file": "BG08_01_00"
