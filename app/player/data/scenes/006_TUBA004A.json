        "offset": [
          234,
          70
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "僕はペコリと頭を下げた。"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（昼）",
        "file": "BG08_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・私服０１・通常１",
        "body": "CH05B_01_01_003_01",
