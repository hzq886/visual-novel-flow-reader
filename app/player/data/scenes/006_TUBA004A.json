        "body": "CH05B_01_01_003_01",
        "face": "CH05B_01_01_101_01",
        "offset": [
          234,
          70
        ]
      }
    },
    {
      "kind": "narration",
      "lines": [
        "そのまま僕たちが二階へ行こうとすると、楓さんが",
        "つぶやくように言う。"
      ],
      "bg": {
        "label": "#背景・楠木家リビング（昼）",
        "file": "BG08_01_00"
      },
      "sprite": {
        "label": "楓（中）・通常１（昼）・私服０１・通常１",
        "body": "CH05B_01_01_003_01",
        "face": "CH05B_01_01_101_01",
        "offset": [
          234,
          70
        ]
